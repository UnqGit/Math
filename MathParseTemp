// The class that does all the magic.

// Many things have a string literal version, this is because we have std::string& as the argument which would take
// an address but it'll give no pointer for string literal version so we have to copy it as const char*.
class expression {

  // Public method to be used.
  public:

    // Default constructor.
    expression() {}

    // Constructor with allowance of toggling variable allowance.
    expression(bool allow_var): allow_variable(allow_var) {}

    // Constructor with expression string input and variable toggling option.
    expression(const std::string &input, bool allow_var = true): entered_expression(input), allow_variable(allow_var) {
      this -> clean();
    }

    // Constructor with expression const string literals without refernce so it doesn't point to nothing
    // and gives a copy which is more suitable here, also a variable toggling option.
    expression(const char* input, bool allow_var = true): allow_variable(allow_var), entered_expression(input) {
      this -> clean();
    }

    // Copy constructor.
    expression(const expression &other): entered_expression(other.entered_expression), modified_expression(other.modified_expression),
    anomaly(other.anomaly), allow_variable(other.allow_variable), err_log(other.err_log) {
      this -> clean();
    }

    // Main function to be used.
    expression &clean() noexcept {

      if(!this -> anomaly) return *this;

      this -> anomaly = false;

      // Initialization.
      std::string &unmodified = this -> entered_expression;
      std::string &input = this -> modified_expression;
      input = unmodified;
      if(unmodified.empty()) {
        this -> anomaly = true;
        this -> err_log = err_empty_string;
        return *this;
      }
      bool flag = false;
      
      bool is_unicode_present = false;
      if(input_validation_normalisation(input, is_unicode_present)) {
        this -> err_log = err_invalid_characters;
        this -> anomaly = true;
        return *this;
      }

      // Convert common aliases to a unified function name.
      func_name_norm(input);

      // Clean basic decimal mistake and continuous chain of [+-] and convert unicode to ASCII characters.
      basic_cleanup(input, is_unicode_present);

      // Check for invalid decimal usage.
      if(input.find(dot) != std::string::npos) invalid_decimal(input);
      if(this -> anomaly) return *this;

      // Make parenthesis even.
      app_paren(input, flag);

      // Remove empty parenthesis.
      if(input.find(empty_paren) != std::string::npos) remove_empt(input, flag);

      // Convert implict multiplication to explicit.
      implicit_mult(input);
      if(this -> anomaly) return *this;

      // Check if use of commas is appropriate.
      if(input.find(comma_str) != std::string::npos) valid_commas(input);
      if(this -> anomaly) return *this;

      // Convert '!' to the function call "ftrl()".
      if(input.find(exclaimation) != std::string::npos) factorial_convert(input);
      if(this -> anomaly) return *this;

      // Change √('#') to sqrt() and remove empty parenthesis potentially created by it or above few functions.
      if(input.find(hash) != std::string::npos) add_sqrt(input);
      if(input.find(empty_paren) != std::string::npos) remove_empt(input, flag);

      // Flag malperfomed operations such as '+)'.
      malform_ops(input);
      if(this -> anomaly) return *this;

      // Check if corrcet functions are called and it is appropriately called using a '('.
      app_func(input, flag);
      if(this -> anomaly) return *this;

      // Flag if number of opening and closing parenthesis is uneven.
      int opening_parenthesis = std::count(input.begin(), input.end(), '(');
      int closing_parenthesis = std::count(input.begin(), input.end(), ')');
      if(opening_parenthesis != closing_parenthesis) {
        this -> err_log = err_incorrect_paren_use;
        this -> anomaly = true;
        return *this;
      }

      // Convert (^ + / - *) into function-like format in bodmas order.
      for(int i = 0; i < 5; i++) {
        binary_ops(input, op_str[i]);
        if(this -> anomaly) return *this;
      }

      // Checking if there are () for potential redundancy removal.
      if(input.find(double_open_paren) != std::string::npos) paren_cleaner(input);

      //final flag to check if string is empty(or was made empty using
      //the "()" removal block earlier)
      if(input.empty()) {
        this -> err_log = flag ? err_invalid_parenthesis : err_empty_string;
        this -> anomaly = true;
        return *this;
      }

      // Log if successfully updated.
      this -> err_log = done_modified;

      // Should be able to parse in less than 20µs for most input strings.
      return *this;
    }

