    void func_name_norm(std::string &input) noexcept {
      std::string result;
      result.resize(input.size());
      const char *it = &input[0], *end = &input[input.size()];
      char *k = &result[0], *t = k;
      while(it != end) {
        if(is_lower(*it)) {
          int j = 1;
          while((it + j != end) && is_lower(*(it + j))) j++;
          const std::string *sub = alias_normalisation(it, j);
          if(sub == &emp) {
            std::memcpy(k, it, j);
            k += j;
          }
          else for(const char &c : *sub) *(k++) = c;
          it += j;
        }
        else *(k++) = *(it++);
