namespace parse {

class expression {
  // Public method to be used.
  public:

    // Default constructor.
    expression() {}

    // Constructor with allowance of toggling variable allowance.
    expression(bool allow_var): allow_variable(allow_var) {}

    // Constructor with expression string input and variable toggling option.
    expression(const std::string &input, bool allow_var = true): entered_expression(input), allow_variable(allow_var) {}

    // Copy constructor.
    expression(const expression &other): entered_expression(other.entered_expression), modified_expression(other.modified_expression),
    anamoly(other.anamoly), allow_variable(other.allow_variable), err_log(other.err_log) {}

    // Main function to be used.
    void clean() noexcept {

      if(!this -> anamoly) return;

      this -> anamoly = false;

      // Initialization.
      std::string &unmodified = this -> entered_expression;
      std::string &input = this -> modified_expression;
      input = unmodified;
      if(input.empty()) {
        this -> anamoly = true;
        this -> err_log = err_empty_string;
        return;
      }
      bool flag = false;

      // Early formatting for consistency.
      std::string temp;
      for(int i = 0; i < input.length(); i++) {
        unsigned char c = input[i];
        if(std::isspace(c)) continue;
        else temp += std::isupper(c) ? std::tolower(c) : c;
      }
      input = temp;

      // Check if superscript is directly followed by a decimal which is likely to be mistake.
      if(pow_dec_wrong(input)) {
        this -> err_log = err_decimal_after_superscript;
        this -> anamoly = true;
        return;
      }

      // Check for any character which isn't in the allowed character set.
      if(invalid_char(input)) {
        this -> err_log = err_invalid_characters;
        this -> anamoly = true;
        return;
      }

      // Convert common aliases to a unified function name.
      func_name_norm(input);

      // Clean basic decimal mistake and continuous chain of [+-] and convert unicode to ASCII characters.
      basic_cleanup(input);

      // Check for invalid decimal usage.
      invalid_decimal(input);
      if(this -> anamoly) return;

      // Make parenthesis even.
      app_paren(input, flag);

      // Remove empty parenthesis.
      remove_empt(input, flag);

      // Convert implict multiplication to explicit.
      implicit_mult(input);
      if(this -> anamoly) return;

      // Check if use of commas is appropriate.
      valid_commas(input);
      if(this -> anamoly) return;

      // Convert '!' to the function call "ftrl()".
      factorial_convert(input);
      if(this -> anamoly) return;

      // Change √('#') to sqrt() and remove empty parenthesis potentially created by it.
      if(input.find(hash) != std::string::npos) add_sqrt(input);
      remove_empt(input, flag);

      // Flag malperfomed operations such as '+)'.
      malform_ops(input);
      if(this -> anamoly) return;

      // Check if functions are proceeded by a '('.
      app_func_call(input, flag);
      if(this ->  anamoly) return;

      // Check if only appropriate functions / variables are present.
      app_func_name(input);
      if(this -> anamoly) return;

      // Flag if number of opening and closing parenthesis is uneven.
      int opening_parenthesis = std::count(input.begin(), input.end(), '(');
      int closing_parenthesis = std::count(input.begin(), input.end(), ')');
      if(opening_parenthesis != closing_parenthesis) {
        this -> err_log = err_incorrect_paren_use;
        this -> anamoly = true;
        return;
      }

      // Convert (^ + / - *) into function-like format in bodmas order.
      for(int i = 0; i < 5; i++) {
        binary_ops(input, call[i]);
        if(this -> anamoly) return;
      }

      // Checking if there are () for potential redundancy removal.
      if(input.find(open_paren) != std::string::npos) paren_cleaner(input);
      if(this -> anamoly) return;
      
      //final flag to check if string is empty(or was made empty using
      //the "()" removal block earlier)
      if(input.empty()) {
        this -> err_log = flag ? err_invalid_parenthesis : err_empty_string;
        this -> anamoly = true;
        return;
      }

      // Log if successfully updated.
      this -> err_log = done_modified;

      // Should be able to parse in 40-70 µs for most input strings.
    }

    // Provide the input stirng.
    std::string original() const noexcept {
      return this -> entered_expression;
    }

    // Resturn the error message or the modified expression depending on if it was parsed correctly.
    std::string result() const noexcept {
      return this -> anamoly ? this -> err_log : this -> modified_expression;
    }

    // Check for if the parsing was done successfully.
    bool is_safe() const noexcept {
      return !this -> anamoly;
    }

    // For exchanging with another expression string, does NOT modify on change.
    expression &operator=(const std::string &new_expr) noexcept {
      this -> entered_expression = new_expr;
      this -> modified_expression.clear();
      this -> anamoly = true;
      this -> err_log = err_not_modified;
      return *this;
    }

    // Return the outermost function name or the entire expression if there isn't a function.
    std::string om_function() const noexcept {
      if(this -> anamoly) return empty_string;
      size_t t = this -> modified_expression.find(open_paren);
      if(t == std::string::npos) return empty_string;
      return this -> modified_expression.substr(0, t);
    }

    // Check if the outermost function is a binary function.
    bool is_om_binary() const noexcept {
      size_t t = modified_expression.find(open_paren);
      if(this -> anamoly || t == std::string::npos) return false;
      return binary_funcs.find(this -> modified_expression.substr(0, t)) != binary_funcs.end();
    }

    // Check for unary functions.
    bool is_om_unary() const noexcept {
      if(this -> anamoly) return false;
      size_t t = modified_expression.find(open_paren);
      return (t == std::string::npos) || binary_funcs.find(this -> modified_expression.substr(0, t)) == binary_funcs.end();
    }

    // Provide the first inner string inside the parenthesis.
    std::string inner_string() const noexcept {
      size_t t  = this -> modified_expression.find(open_paren);
      if(this -> anamoly || t == std::string::npos) return empty_string;
      int len = this -> modified_expression.length();
      return this -> modified_expression.substr(t + 1, len - (t + 2));
    }

    // Provide the first inner expression (enire expression if unary or first expression from binary functions)
    // as string if present.
    std::string first_expression_str() const noexcept {
      if(this -> anamoly) return empty_string;
      size_t t = this -> modified_expression.find(open_paren);
      if(t == std::string::npos) return this -> modified_expression;
      size_t len = this -> modified_expression.length();
      std::string inner_expr = this -> modified_expression.substr(t + 1, len - (t + 2));
      if(this -> is_om_unary()) return inner_expr;
      int parenthesis = 0, i = t + 1;
      const std::string &input = this -> modified_expression;
      for(; i < len - 1; i++) {
        if(input[i] == '(') parenthesis++;
        else if(input[i] == ')') parenthesis--;
        else if(input[i] == ',') if(parenthesis == 0) break;
      }
      return input.substr(t + 1, i - (t + 1));
    }

    // Provide the second inner expression (no expression if unary or second expression from binary functions)
    // as string if present.
    std::string second_expression_str() const noexcept {
      if(this -> anamoly || this -> is_om_unary()) return empty_string;
      size_t t = this -> modified_expression.find(open_paren);
      size_t len = this -> modified_expression.length();
      std::string inner_expr = this -> modified_expression.substr(t + 1, len - (t + 2));
      int parenthesis = 0, i = t + 1;
      const std::string &input = this -> modified_expression;
      for(; i < len - 1; i++) {
        if(input[i] == '(') parenthesis++;
        else if(input[i] == ')') parenthesis--;
        else if(input[i] == ',') if(parenthesis == 0) break;
      }
      return input.substr(i + 1, len - 2 - i);
    }

    // Provide the first inner expression (enire expression if unary or first expression from binary functions)
    // as expression if present.
    expression first_expression() const noexcept {
      if(this -> anamoly) return expression();
      size_t t = this -> modified_expression.find(open_paren);
      if(t == std::string::npos) return *this;
      size_t len = this -> modified_expression.length();
      std::string inner_expr = this -> modified_expression.substr(t + 1, len - (t + 2));
      if(this -> is_om_unary()) {
        expression inner;
        inner.entered_expression = inner_expr;
        inner.modified_expression = inner_expr;
        inner.anamoly = false;
        inner.allow_variable = this -> allow_variable;
        inner.err_log = this -> err_log;
        return inner;
      }
      int parenthesis = 0, i = t + 1;
      const std::string &input = this -> modified_expression;
      for(; i < len - 1; i++) {
        if(input[i] == '(') parenthesis++;
        else if(input[i] == ')') parenthesis--;
        else if(input[i] == ',') if(parenthesis == 0) break;
      }
      std::string new_expr = input.substr(t + 1, i - (t + 1));
      expression result;
      result.entered_expression = new_expr;
      result.modified_expression = new_expr;
      result.anamoly = false;
      result.allow_variable = this -> allow_variable;
      result.err_log = this -> err_log;
      return result;
    }

    // Provide the second inner expression (no expression if unary or second expression from binary functions)
    // as expression if present.
    expression second_expression() const noexcept {
      if(this -> anamoly || this -> is_om_unary()) return expression();
      size_t t = this -> modified_expression.find(open_paren);
      size_t len = this -> modified_expression.length();
      std::string inner_expr = this -> modified_expression.substr(t + 1, len - (t + 2));
      int parenthesis = 0, i = t + 1;
      const std::string &input = this -> modified_expression;
      for(; i < len - 1; i++) {
        if(input[i] == '(') parenthesis++;
        else if(input[i] == ')') parenthesis--;
        else if(input[i] == ',') if(parenthesis == 0) break;
      }
      std::string new_expr = input.substr(i + 1, len - 2 - i);
      expression result;
      result.entered_expression = new_expr;
      result.modified_expression = new_expr;
      result.anamoly = false;
      result.allow_variable = this -> allow_variable;
      result.err_log = this -> err_log;
      return result;
    }

    // Swaping mechanism with another expression.
    expression &swap(expression &other) {
      std::swap(this -> entered_expression, other.entered_expression);
      std::swap(this -> modified_expression, other.modified_expression);
      std::swap(this -> allow_variable, other.allow_variable);
      std::swap(this -> err_log, other.err_log);
      std::swap(this -> anamoly, other.anamoly);
      return *this;
    }

    // Reset the class back to default.
    expression &clear() noexcept {
      this -> entered_expression.clear();
      this -> modified_expression.clear();
      this -> anamoly = true;
      this -> allow_variable = true;
      this -> err_log = err_not_modified;
      return *this;
    }

    // Update the input string with a new string and optionally cleanse it.
    expression &update(const std::string &new_expr, const bool &cleanse = false) noexcept {
      this -> entered_expression = new_expr;
      this -> modified_expression.clear();
      this -> anamoly = true;
      this -> err_log = err_not_modified;
      if(cleanse) this -> clean();
      return *this;
    }

    // Direct and no variable_check_shenanigan function checker. 
    bool is_set_function() const noexcept {
      return this -> allow_variable;
    }

    // Check if variable is present in the expression.
    bool is_function() const noexcept {
      if(this -> anamoly) return false;
      if(!this -> allow_variable) return false;
      size_t t = this -> modified_expression.find(x_str);
      while(t != std::string::npos) {
        if(t == 0 || (t > 0 && this -> modified_expression[t - 1] != 'e')) return true;
        t = this -> modified_expression.find(x_str, t + 1);
      }
      return false;
    }

    // Check if any variable is present in the expression.
    bool is_constant() const noexcept {
      if(this -> anamoly) return false;
      return !this -> is_function();
    }

    // Turn variable allowing variable off and log if a variable is present.
    void make_constant() noexcept {
      if(this -> anamoly) {
        this -> allow_variable = false;
        return;
      }
      if(this -> allow_variable) {
        if(this -> is_function()) {
          this -> err_log = err_var_where_not_allowed;
          this -> anamoly = true;
        }
        this -> allow_variable = false;
      }
    }

    // No need to check anything in here, just turn the flag on.
    void make_function() noexcept {
      this -> allow_variable = true;
    }
  
  // Helper functions.
  private:

    //Checks if a string of lowercase letters more than a letter
    //long is followed by a '(' or not (to check if functions are followed
    //by a '(').
    void app_func_call(const std::string &input, bool flag) noexcept {
      int to_check = 0;
      for(int i = 0; i < input.size(); i++) {
        if(std::islower(input[i])) to_check++;
        else {
          if(to_check == 0) continue;
          if(to_check > 1) {
            if(input[i] != '(') {
              if(flag) this -> err_log = err_no_arg_func;
              else this -> err_log = err_func_not_called;
              this -> anamoly = true;
              return;
            }
          }
          to_check = 0;
        }
      }
      if(to_check > 1) {
        if(flag) this -> err_log = err_no_arg_func;
        else this -> err_log = err_func_not_called;
        this -> anamoly = true;
        return;
      }
    }

    // Checks if continuous set of strings in the modified string is
    // an intended function via a map to check easily.
    void app_func_name(const std::string &input) noexcept {

      std::string to_check;
      for(int i = 0; i < input.size(); i++) {

        // Store continuous set of lowercase letters into a temporary string.
        if(std::islower(input[i])) to_check += input[i];
        else {

          // If the prevous letter also wasn't an alphabet.
          if(to_check.empty()) continue;

          // If the string stored as potential functions aren't
          // present in the map, flag them otherwise reset and continue.
          else {
            if(allowed_functions.count(to_check)) {
              if(to_check == x_str && (!this -> allow_variable)) {
                this -> err_log = err_var_where_not_allowed;
                this -> anamoly = true;
                return;
              }
              to_check.clear();
              continue;
            }
            else {
              this -> err_log = err_invalid_char_stream + to_check + apostrophe_dot;
              this -> anamoly = true;
              return;
            }
          }
        }
      }

      // If the temporary variable isn't empty then check it as a
      // necessary function or variable, if not, then flag.
      if(!to_check.empty() && !allowed_functions.count(to_check)) {
        this -> err_log = err_invalid_char_stream + to_check + apostrophe_dot;
        this -> anamoly = true;
        return;
      }
    }

    // Checks if there are correct numbers of opening and closing
    // parenthesis, if not add where needed.
    void app_paren(std::string &input, bool &flag) noexcept {
      int parenthesis = 0;
      for(int i = 0; i < input.size(); i++) {
        if(input[i] == '(') {
          parenthesis++;
        }
        else if(input[i] == ')') {
          if(parenthesis == 0) {
            input = "(" + input;
            flag = true;
            i++;
          }
          else parenthesis--;
        }  
      }
      input += std::string(parenthesis, ')');
    }

    // Call at last of the cleaner function to ensure this works properly.
    void paren_cleaner(std::string &input) noexcept {
      // Parenthesis count check is done before calling
      // this function.
      // Initialize a stack to keep track of opening
      // parenthesis index and potential for removal.
      std::stack<std::pair<size_t, bool>> holder;

      // Only need to iterate through the string once.
      for(int i = 0; i < input.length(); i++) {

        if(input[i] == '(') {

          //If the opening parenthesis isn't preceded by
          //a function, add to the potential.
          if(i > 0) {
            char ch = input[i - 1];
            if(!std::islower(ch)) holder.push({i, true});
            else holder.push({i, false});
          }

          //If the parenthesis is at the start, still add potential for removal.
          else holder.push({i, true});
        }

        else if(input[i] == ')') {

          // Error check.
          if(holder.empty() || (!holder.empty() && (holder.top().first == i - 1))) {
            this -> err_log = err_incorrect_paren_use;
            this -> anamoly = true;
            return;
          }

          if(holder.top().second) {

            // If it had potential remove the parenthesis. 
            input.erase(i, 1);
            input.erase(holder.top().first, 1);
            i -= 2;
          }

          // Remove the top-most nest from the stack.
          holder.pop();
        }
      }
    }

    void basic_cleanup(std::string &input) noexcept {
      // Convert unicode operators and constants into
      // normal operators and placeholders respectfully
      // reason why exp and sec are chaned temporarily is
      // so that exp doesn't become 2.718*xp
      // and pi should be converted before exp for the cases
      // such as expi where it should be '2.718*x*3.141'.

      for(int i = 0; i < 26; i += 2) {
        size_t t = input.find(temporary_conversion[i]);
        while(t != std::string::npos) {
          input.replace(t, temporary_conversion[i].length(), temporary_conversion[i + 1]);
          t = input.find(temporary_conversion[i], t + temporary_conversion[i].length() - 1 - (temporary_conversion[i] == sqrt_str ? 1 : 0));
          // Subtraction by 1 is needed for √ because it is of multibyte natue (unicode).
        }
      }

      // Add approapriate operators where needed.
      for(int i = 0; i < 24; i += 2) {
        size_t t = input.find(unicode_conversion[i]);
        while(t != std::string::npos){
          std::string substring = unicode_conversion[i];
          int update = 0;
          if(t > 0 && (basic_cleanup_lookup.count(input[t - 1]) || std::islower(input[t - 1]))) substring = (i < 20 ? carret_str : asterisk_str) + substring;

          // We can't check the immediate next character as
          // superscripts are unicode and not single byte ASCII.
          if((t + unicode_conversion[i].length() < input.size()) && ((std::islower(input[t + unicode_conversion[i].length()])) ||
          (basic_cleanup_lookup.count(input[t + unicode_conversion[i].length()]) && input[t + unicode_conversion[i].length()] != ')'))) {
            substring += asterisk_str;
            update++;
          }
          input.replace(t, unicode_conversion[i].size(), substring);
          t = input.find(unicode_conversion[i], t + substring.length() - update);
        }
      }

      // Reason why this couldn't be done in the first loop itself
      // is that something like 2³⁴ would become 2^3^4.
      for(int i = 0; i < 24; i += 2) {
        size_t t = input.find(unicode_conversion[i]);
        while(t != std::string::npos) {
          input.replace(t, unicode_conversion[i].length(), unicode_conversion[i + 1]);
          t = input.find(unicode_conversion[i], t + unicode_conversion[i].length() - 1 - (i < 20 ? 1 : 0));
          // Due to multibyte nature of superscripts we have to subtract 1.
        }
      }

      // Normalize signs and decimals.
      for(int i = 0; i < input.size(); i++) {
        if(input[i] == '+' || input[i] == '-') {
          int count = (input[i] == '-'), j = 1;

          // If the current character (we can check characters safely
          // now that we have changed unicode characters into
          // ASCII characters) is a '+' or a '-', find the next character
          // which isn't one of them and replace the entire substring
          // with equivalent sign.

         while((i + j) < input.size() && (input[i + j] == '+' || input[i + j] == '-')) {
            count += input[i + j] == '-';
            j++;
          }
          if(j > 1) input.replace(i, j, (count & 1 ? minus : plus));
        }

        // If a decimal is found, check if it follows a number, if not insert
        // a 0 before it, and if it isn't followed by a number, remove it.

        else if(input[i] == '.') {
          if(i == input.size() - 1 || (i < input.size() - 1 && !std::isdigit(input[i + 1]))) {
            input.erase(i, 1);
            i--;
          }
          if(i > -1 && (input[i] == '.') && (i == 0 || (i > 0 && !std::isdigit(input[i - 1])))) {
            input.insert(i, zero);
            i++;
            if(i == input.size() - 1 || (i < input.size() - 1 && !std::isdigit(input[i + 1]))) {
              input.erase(i, 1);
              i--;
            }
          }
        }
      }
    }

    // Replace the '#'(ASCII)(temporarily replaced for '√'(unicode)) with sqrt() format.
    void add_sqrt(std::string &input) noexcept {

      // Sets of delimiters to check from.
      std::unordered_set<char> delimiter_map {'+','-','*','/','^',',',')'};
      // Cannot save this in the constant section as we are updating the map.

      // Count the number of #, which we have to change.

      int count = std::count(input.begin(), input.end(), '#');
      int t = input.length() - 1, h, parenthesis = 0;

      for(int i = 0; i < count; i++) {

        // Find the first '#' from back(right associative)
        // starting from previous index of '#' found.
        for(h = t+1; h >= 0; h--)
          if(input[h] == '#') {t = h; break;}

        // Replace the '#' with 'sqrt('.
        input.replace(t, 1, sqrt_func_str);

        // Start from the newer index which is changed by
        // adding the 5 character wide "sqrt("
        // and find the appropriate index to insert closing
        // parenthesis.
        t += 5;
        int j = t;
        for(; j < input.length(); j++) {
          if((delimiter_map.count(input[j])) && parenthesis == 0) {
            if(j == t && (input[j] == '+' || input[j] == '-')) continue;
            if(!(j == t + 1 && ((input[j] == '(') && (input[j - 1] == '+' || input[j - 1] == '-')))) break;
          }
          if(input[j] == '(') parenthesis++;
          else if(input[j] == ')') parenthesis--;
        }
        if(j < input.size() - 1) {
          input.insert(j, close_paren);
        }
        else input += close_paren;
      }
    }

    // Convert (^ / * + -) into function like-structure.
    void binary_ops(std::string &input, char delimiter) noexcept {

      // Delimiters to make sure we insert at correct position.
      std::unordered_set<char> delimiter_map {'+','-','*','/','^','(',','};
      // Cannot save this in the constant section as we are updating the map.

      // Initialize function name to be added and the potential
      // error message using a switch and based on input delimiter
      std::string function, error_name;
      bool check_hang = true;
      switch(delimiter) {
        case'^':
          function = pow_func_str;
          error_name = err_full_exp;
          break;
        case'/':
          function = div_func_str;
          error_name = err_full_div;
          break;
        case'*':
          function = mul_func_str;
          error_name = err_full_mul;
          break;
        case'-':
          function = sub_func_str;
          error_name = err_full_sub;
          check_hang = false;
          break;
        case'+':
          function = add_func_str;
          error_name = err_full_add;
          check_hang = false;
          break;
      }

      // If delimiter is '^' starting position is end of the string
      // otherwise at the start to respect the associativity of operations.
      int index = delimiter == '^' ? input.length() - 2 : 0, count = std::count(input.begin(), input.end(), delimiter);

      // Used stop as a lambda to account for update in string and indices.
      auto stop = [&](){return delimiter == '^' ? 0 : input.length(); };
      // To find the next delimiter go back by 1 if delimiter is carret
      // otherwise go ahead for associativity.
      int update = delimiter == '^' ? -1 : 1, offset = delimiter == '^' ? 1 : 0;

      for(int i = 0; i < count; i++) {

        for(int j = index + offset; j != stop(); j += update) {
          if(input[j] == delimiter) {
            index = j;
            break;
          }
        }

        input[index] = ',';
        if(index == 0 || (index > 0 && delimiter_map.count(input[index - 1]))) {

          // If the operator can't have no first argument
          // which are '*','/'&'^' log error and return.
          if(check_hang) {
            this -> err_log = err_hanging;
            this -> err_log += error_name;
            this -> err_log += err_operator;
            this -> anamoly = true;
            return;
          }

          //If the standalone operator is '+' erase it.
          if(delimiter == '+') {
            input.erase(index, 1);
            index--;
            continue;
          }

          // If the standalone operator is '-' subtract from 0.
          else {
            input.insert(index > 0 ? index : 0, sub_0_func_str);
            index += 5;
          }
        }

        // If not standalone find the appropiate left position
        // and insert the function name.
        else {
          int parenthesis = 0, j = index - 1;
          for(; j > 0; j--) {
            if(delimiter_map.count(input[j]) && parenthesis == 0) break;
            if(input[j] == ')') parenthesis++;
            else if(input[j] == '(') parenthesis--;
          }
          input.insert(j <= 0 ? 0 : j + 1, function);
          index += 4;
        }

        // Erase '(' from map as to make sure we don't stop
        // anywhere prematurely and add ')' as a new delimiter.
        delimiter_map.erase('(');
        delimiter_map.insert(')');

        int j = index + 1, parenthesis=0;
        for(;j < input.length(); j++) {
          if(delimiter_map.count(input[j]) && parenthesis == 0) {
            if((delimiter != '+' && delimiter != '-') && (input[j] == '+' || input[j] == '-') && j == index + 1) continue;
              break;
          }
          if(input[j] == ')') parenthesis--;
          else if(input[j] == '(') parenthesis++;
        }

        // If stopped index is right after index it is a trailing
        // operator and so flag it as error.
        if(j - index == 1 || index == input.length() - 1) {
          this -> err_log = err_trailing;
          this -> err_log += error_name;
          this -> err_log += err_operator;
          this -> anamoly = true;
          return;
        }

        // Insert ')' at the position found.
        else if(j < input.length() - 1) input.insert(j, close_paren);
        else input += close_paren;

        // Reset map to default.
        delimiter_map.erase(')');
        delimiter_map.insert('(');
      }
    }

    // Convert aliases to normal function names.
    void func_name_norm(std::string &input) noexcept {

      // Converts several aliases to a consistent set of functions
      // things like cosine also get convered because of the order
      // in which they are performed ultimately reducing the number
      // of loops needed.
      // eg, cosine->co-sine->co-sin->cosin->cos.

      for(int i = 0; i < 24; i+=2) {

        size_t t = input.find(alias_conversion[i]);

        while(t != std::string::npos) {
          // A separate check for "arc" to remove incorrectly flagging
          // arcot, which would've become aot without separation.
          if(alias_conversion[i] == "arc") {
            if((t + alias_conversion[i].length()) < input.length() &&
            !(input[t + alias_conversion[i].length()] == 'o'))
            input.replace(t, alias_conversion[i].length(), alias_conversion[i + 1]);
          }

          else input.replace(t, alias_conversion[i].length(), alias_conversion[i + 1]);
          t = input.find(alias_conversion[i], t + alias_conversion[i + 1].length());

        }
      }
    }

    // Implicit to explicit multiplication.
    void implicit_mult(std::string &input) noexcept {

      for(int i = 0; i < input.length(); i++) {

        // Sqrt rule.
        if(input[i] == '#') {
          if(i > 0 && implicit_mult_valid_chars.count(input[i - 1]) &&
          !(input[i - 1]=='(' || input[i - 1] == '#')) {
            input.insert(i, "*");
            i++;
          }

          // Error check.
          if((i + 1) < input.size() && input[i + 1] == ')') {
            this -> err_log = "INVALID PARENTHESIS, NO ARGUMENT INSIDE.";
            this -> anamoly = true;
            return;
          } 

        }

        // Variable rule.
        else if(input[i] == 'x') {
          if(i > 0 && input[i - 1] == 'e') continue;
          if(i > 0 && implicit_mult_valid_chars.count(input[i - 1]) &&
          !(input[i - 1] == '(' || input[i - 1] == '#')) {
            input.insert(i, "*");
            i++;
          }
          if((i + 1) < input.length() && (std::islower(input[i + 1]) || (
          (implicit_mult_valid_chars.count(input[i + 1]) && input[i + 1] != ')')))) {
            input.insert(i + 1, "*");
          }
        }

        // Function rule.
        else if(std::islower(input[i])) {
          if(i > 0 && (std::isdigit(input[i - 1]) || input[i - 1] == ')')) {
            input.insert(i, "*");
            i++;
          }
        }

        // Factorial symbol rule.
        else if(input[i] == '!') {
          if((i + 1) < input.size() && (std::isalnum(input[i + 1]))) input.insert(i + 1, "*");
        }

        // Opening parenthesis rule.
        else if(input[i] == '(') {
          if(i > 0 && implicit_mult_valid_chars.count(input[i - 1]) &&
          !(input[i - 1] == '(' || input[i - 1] == '#')) {
            input.insert(i, "*");
            i++;
          }

          // Error check.
          if((i + 1) < input.size() && input[i + 1] == ')') {
            this -> err_log = "INVALID PARENTHESIS, NO ARGUMENT INSIDE.";
            this -> anamoly = true;
            return;
          } 

        }

        // Closing parenthesis rule.
        else if(input[i] == ')') {
          if((i + 1) < input.length() && implicit_mult_valid_chars.count(input[i + 1]) &&
          !(input[i + 1] == ')' || input[i + 1] == '!')) {
            input.insert(i + 1, "*");
          }
        }
      }
    }

    // Check if a superscript is directly followed by
    // a decimal which is likely to be an error.
    bool pow_dec_wrong(const std::string &input) const noexcept {
      for(int i = 0; i < 10; i++) {
        size_t t = input.find(super[i]);
        while(t != std::string::npos) {
          if((t + super[i].length() < input.length()) && input[t + super[i].length()] == '.') return true;
          t = input.find(super[i], t + super[i].length());
        }
      }
      return false;
    }

    // Check for any invalid characters that aren't allowed.
    bool invalid_char(const std::string &input) const noexcept {
      for (int i = 0; i < input.size(); ) {
        unsigned char c = input[i];
        int len = 1;
        // Shenanigans for unicode.
        if ((c & 0x80) == 0) len = 1;
        else if ((c & 0xE0) == 0xC0) len = 2;
        else if ((c & 0xF0) == 0xE0) len = 3;
        else if ((c & 0xF8) == 0xF0) len = 4;
        else return true;
        if((i + len) > input.size()) return true;
        if (!valid_characters.count(input.substr(i, len))) return true;
        i += len;
      }
      return false;
    }

    // Remove empty parenthesis.
    void remove_empt(std::string &input, bool &flag) const noexcept {
       // Remove any empty parenthesis and turn flag boollean
       // to true for further correct error_message.
       size_t t = input.find("()");
       while(t != std::string::npos) {
         flag = true;
         input.replace(t, 2, "");
         t = input.find("()", t == 0 ? 0 : t - 1);
       }
     }

    // Transform operators into explicit function calls with appropiate error flagging.
    void malform_ops(std::string &input) noexcept {

      // Flag early if encountering an empty string.
      if(input.empty()) {
        this -> err_log = "NO EXPRESSION.";
        this -> anamoly = true;
        return;
      }

      // Flag lone signs.
      if(input.size() == 1 && primary_ops.count(input.front())) {
        this -> err_log = "NO FUNCTIONALITY TO OPERATOR.";
        this -> anamoly = true;
        return;
      }

      for(int i = 0; i < input.length(); i++) {

        // Handled in other functions too but flag for safety.
        if(input[i] == '(' && (i + 1) < input.length() && input[i + 1] == ')') {
          this -> err_log = "EMPTY PARENTHESIS, NO ARGUMENT.";
          this -> anamoly = true;
          return;
        }

        if(primary_ops.count(input[i])) {
      
          // If a unary plus sign at the start and input size is not greater than 1, flag it.
          if(i == 0 && input[i] == '+') {
            if(input.size() != 1) {
              input.erase(i, 1);
              i--;
              continue;
            }
            else {
              this -> err_log = "NO FUNCTIONALITY TO OPERATOR.";
              this -> anamoly = true;
            }
          }

          // Rules for error flag or unary plus sign removal.
          if(i > 0) {
            if(input[i - 1] == '(' && input[i] != '-') {
              if(input[i] == '+') {
                input.erase(i, 1);
                i--;
                continue;
              }
              this -> err_log = "HANGING OPERATOR AFTER PARENTHESIS.";
              this -> anamoly = true;
              return;
            }
            if((i + 1) < input.size()) {
              if(input[i + 1] == ')') {
                this -> err_log = "TRAILING OPERATOR BEFORE PARENTHESIS.";
                this -> anamoly = true;
                return;
              }
              else if(primary_ops.count(input[i + 1])) {
                if(input[i + 1] == '+') {
                  input.erase(i + 1, 1);
                  i--;
                  continue;
                }
                else if(!sign.count(input[i]) && input[i + 1] == '-') continue;
                else {
                  this -> err_log = "MALFORMED OPERATORS.";
                  this -> anamoly = true;
                  return;
                }
              }
            }
            else {
              this -> err_log = "TRAILING OPERATOR.";
              this -> anamoly = true;
              return;
            }
          }
          else if(!sign.count(input[i]) || ((i + 1) < input.length() && sign.count(input[i + 1]))) {
            this -> err_log = "HANGING OPERATOR.";
            this -> anamoly = true;
            return;
          }
        }
      }
    }

    // Convert from implicit '!' to explicit function calls of "ftrl()".
    void factorial_convert(std::string &input) noexcept {
      size_t t = input.find(exclaimation);
      if(t == 0) {
        this -> err_log = invalid_fact_place;
        this -> anamoly = true;
        return;
      }
      while(t != std::string::npos) {
        int parenthesis = 0, i = t - 1;
        if(ops.find(input[t - 1]) != ops.end() || input[t - 1] == '(') {
          this -> err_log = err_no_arg_fact;
          this -> anamoly = true;
          return;
        }
        input.replace(t, 1, close_paren);
        for(; i >= 0; i--) {

          if(input[i] == '(') {
            if(parenthesis == 0) break;
            parenthesis--;
            if(parenthesis < 0) {
              this -> err_log = err_incorrect_paren_use;
              this -> anamoly = true;
              return;
            }
          }

          else if((i == 0 || ops.find(input[i]) != ops.end())) {
            if(parenthesis == 0) {
              break;
            }
            else {
              this -> err_log = invalid_fact_place;
              this -> anamoly = true;
              return;
            }
          }

          else if(input[i] == ')') parenthesis++;

        }

        input.insert(i == 0 ? i : i + 1, ftrl_func_str);
        t = input.find(exclaimation, t + 4);
      }

    }

    // Make sure commmas are only present in binary functions and with correct conditions at that.
    void valid_commas(const std::string &input) noexcept {

      std::string temp;
      int functions = 0, parenthesis = 0;

      // A stack to hold the amount of indices present before encountering a binary function,
      // and a bool containing the data if we've encountered a comma in the function.
      std::stack<std::pair<int, bool>> parenthesis_count;
      for(int i = 0; i < input.size(); i++) {
        if(std::islower(input[i])) {
          temp += input[i];
        }
        else {
          if(input[i] == '(') {
            if(!temp.empty() && binary_funcs.find(temp) != binary_funcs.end()) {
              parenthesis_count.push({parenthesis, false});
            }
            parenthesis++;
          }
          else if(input[i] == ')') {
            parenthesis--;
            if(parenthesis < 0) {
              this -> err_log = err_incorrect_paren_use;
              this -> anamoly = true;
              return;
            }
            if(!parenthesis_count.empty() && parenthesis_count.top().first == parenthesis) {
              if(!parenthesis_count.top().second) {
                this -> err_log = err_no_comma;
                this -> anamoly = true;
                return;
              }
              parenthesis_count.pop();
            }
          }
          else if(input[i] == ',') {
            if(parenthesis_count.empty() || parenthesis_count.top().first != parenthesis - 1) {
              this -> err_log = err_used_comma;
              this -> anamoly = true;
              return;
            }
            if(parenthesis_count.top().second) {
              this -> err_log = err_mul_comma;
              this -> anamoly = true;
              return;
            }
            if((i == 0) || invalid_precedence.find(input[i - 1]) != invalid_precedence.end()) {
              this -> err_log = err_no_first_arg;
              this -> anamoly = true;
              return;
            }
            if((i == input.size() - 1) || invalid_subsidence.find(input[i + 1]) != invalid_subsidence.end()) {
              this -> err_log = err_no_second_arg;
              this -> anamoly = true;
              return;
            }
            parenthesis_count.top().second = true;
          }
          temp.clear();
        }
      }
  
    }

    // Make sure decimals has valid format.
    void invalid_decimal(const std::string &input) noexcept {

      // Early empty string check.
      if(input.empty()) {
        this -> err_log = err_empty_string;
        this -> anamoly = true;
        return;
      }
      size_t t = input.find(dot);
      if(t == 0) {
        this -> err_log = err_hanging_dec;
        this -> anamoly = true;
        return;
      }

      while(t != std::string::npos) {

        // Check if decimal is preceded by a number.
        if(!std::isdigit(input[t - 1])) {
          this -> err_log = err_dec_not_follows;
          this -> anamoly = true;
          return;
        }

        // If the position is less than the current string length.
        if(t < input.length()) {

          if(!std::isdigit(input[t + 1])) {
            this -> err_log = err_dec_not_followed;
            this -> anamoly = true;
            return;
          }

          else {
            int j = 1;

            // Find the next non-digit character.
            while((t + j) < input.length() && std::isdigit(input[t + j])) j++;

            // If the next non-digit is still within the string.
            if((t + j) < input.length()) {

              // And it is another decimal, flag it.
              if(input[t + j] == '.') {
                this -> err_log = ((t + j == input.length() - 1) ? err_trailing_dec
                : err_mul_dec);
                this -> anamoly = true;
                return;
              }
            }

            // If the only thing present after decimal were digits
            // no further evaluation is needed.
            else return;
          }
        }

        t = input.find(dot, t + 1);
      }
    }

  // Friend operators.
  protected:
    
    // Printing function for ease_of_use.
    void print(std::ostream &os) const {
      os << "\nOriginal: " << this -> entered_expression;
      os << "\nModified: ";
      if(!anamoly && this -> modified_expression.find("(") != std::string::npos) {
        os << '\n';
        int parenthesis = 0;
        std::string string = this -> modified_expression;
        for(int i = 0; i < string.size(); i++) {
          if(string[i] == '(') {
            os << string[i] << "\n";
            parenthesis++;
            os << std::string(2 * parenthesis, ' ');
          }
          else if(string[i] == ')') {
            parenthesis--;
            if(parenthesis < 0) throw std::runtime_error("Unexpected error: parenthesis parsing didn't occur correctly.");
            os << "\n" << std::string(2 * parenthesis, ' ') << string[i];
          }
          else if(string[i] == ',') {
            os << string[i] << "\n" << std::string(2 * parenthesis, ' ');
          }
          else os << string[i];
        }
      }
      else os << this -> modified_expression;
      os << "\nStatus: " << ((anamoly && this -> err_log != "NOT MODIFIED.") ? "" : "No ") << "Anamoly Detected.";
      os << "\nLog: " << this -> err_log << "\n";
    }

    // Output stream operator to print all the useful information.
    friend std::ostream& operator<<(std::ostream& os, const expression& obj){
      obj.print(os);
      return os;
    }

    // To parse a input directly from input stream.
    friend std::istream &operator>>(std::istream &is, expression &obj) {
      std::string line;
      std::getline(is, line);
      obj.update(line, true);
      return is;
    }

  // Private data members.
  private:
    std::string entered_expression;
    std::string modified_expression;
    bool anamoly = true;
    bool allow_variable = true;
    std::string err_log = "NOT MODIFIED.";
};

