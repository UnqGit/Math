  // Valid multibyte (Unicode) characters (as UTF-8 strings).
  const std::string vc_2l[33] {
    "×", "", "", "", "", "", "", "", "", "π", 
    "", "", "", "", "", "", "", "", "", "", 
    "", "¹", "", "", "", "", "", "³", "²", "", 
    "", "·", "÷"
  };
  const std::string vc_3l[15] {
    "√", "⁰", "", "", "", "", "", "", "", "⁸", 
    "⁹", "⁶", "⁷", "⁴", "⁵"
  };

  // Determines if a UTF-8 sequence (1–3 bytes) is a valid character.
  bool is_valid_character(const char *ptr, int size) noexcept {
    unsigned int index;
    switch(size) {
      case 1:
        index = -6 + ((*ptr) % 88);
        return index < 52 && (*ptr) == vc_sch[index];
      case 2:
        index = - 77 + ((unsigned char)(*(ptr + 0))^0 + (unsigned char)(*(ptr + 1))^25);
        return index < 33 && !vc_2l[index].empty() && std::memcmp(ptr, &vc_2l[index][0], 2) == 0;
      case 3:
        index = - 47 + ((unsigned char)(*(ptr + 1))^6 + (unsigned char)(*(ptr + 2))^7);
        return index < 15 && !vc_3l[index].empty() && std::memcmp(ptr, &vc_3l[index][0], 3) == 0;
      default:
        return false;
    }
  }

  inline bool not_valid_embed(const std::string &input) noexcept {
    const size_t &length = input.length();
    switch(length) {
      case 1:
        return input[0] == 'x' || input[0] == 'e';
      case 2:
        return input[0] == 'p';
      default:
        return false;
    }
  }

