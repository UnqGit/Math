    // Direct and no variable_check_shenanigan function checker. 
    bool is_set_function() const noexcept {
      return this -> allow_variable;
    }

    // Check if variable is present in the expression.
    bool is_function() const noexcept {
      if(this -> anomaly) return false;
      if(!this -> allow_variable) return false;
      size_t t = this -> modified_expression.find(x_str);
      while(t != std::string::npos) {
        if(t == 0 || (t > 0 && !invalid_precede_x(this -> modified_expression[t - 1]))) return true;
        t = this -> modified_expression.find(x_str, t + 1);
      }
      return false;
    }

    // Check if any variable is present in the expression.
    bool is_constant() const noexcept {
      if(this -> anomaly) return false;
      return !this -> is_function();
    }

    // Turn variable allowing variable off and log if a variable is present.
    expression &make_constant() noexcept {
      if(this -> anomaly) {
        this -> allow_variable = false;
        return *this;
      }
      if(this -> allow_variable) {
        if(this -> is_function()) {
          this -> err_log = err_var_where_not_allowed;
          this -> anomaly = true;
        }
        this -> allow_variable = false;
      }
      return *this;
    }

    // No need to check anything in here, just turn the flag on.
    expression &make_function() noexcept {
      this -> allow_variable = true;
      return *this;
    }

  // Helper functions.
  private:

    // Validate if a substring of letters in the input forms a valid function name,
    // and ensure it is properly followed by an opening parenthesis '(' if required.
    // Also checks if variables like 'x' are allowed where they appear.
    //
    // Parameters:
    //   input - the full input string to check through
    //   flag  - determines which error message to use if a function lacks arguments
    //
    // Behavior:
    // - Accumulates consecutive lowercase letters up to 4 (max function name length).
    // - If more than 4 letters are found in a row, marks anomaly with an error.
    // - For each accumulated function name, verifies:
    //    * It’s an allowed function name.
    //    * It is followed by '(' if the function expects arguments.
    //    * If the name is 'x' (variable), checks if variables are allowed in this context.
    // - If any check fails, sets the anomaly flag and error message, then returns immediately.
    void app_func(const std::string &input, bool flag) noexcept {
      const char *it = &input[0], *end = it + input.size();
      while(it != end) {
        if(is_lower(*it)) {
          int j = 1;
          while(j < 5 && it + j != end && is_lower(*(it + j))) j++;
          if(j == 5 || !is_allowed_function(it, j)) {
            this -> err_log = err_invalid_char_stream + std::string(it, j) + apostrophe_dot;
            this -> anomaly = true;
            return;
          }
          if(j != 1 && ((it + j) == end || *(it + j) != '(') && !(j == 2 && *it == 'p')) {
            this -> err_log = flag ? err_no_arg_func : err_func_not_called;
            this -> anomaly = true;
            return;
          }
          if(j == 1 && *it == 'x' && !this -> allow_variable) {
            this -> err_log = err_var_where_not_allowed;
            this -> anomaly = true;
            return;
          }
          it += j - 1;
        }
        it++;
      }
    }

    // Ensures the input string has balanced parentheses by:
    // - Counting unmatched closing parentheses and adding opening parentheses at the front if needed.
    // - Counting unmatched opening parentheses and appending closing parentheses at the end.
    //
    // Parameters:
    //   input - the string to check and fix parentheses in (modified in place).
    //   flag  - a boolean reference set to true if any opening parentheses are inserted at the front.
    void app_paren(std::string &input, bool &flag) noexcept {
      int parenthesis = 0, front_paren = 0; // stack like counters.
      const char *it = &input[0], *end = &input[input.size()];
      while(it != end) {
        switch(*(it++)) {
          case '(':
            parenthesis++; break;
          case ')':
            switch(parenthesis) {
              case 0: // if no matching parnethesis we have to add at the start.
                front_paren++; break;
              default:
                parenthesis--;
            }
        }
      }
      if(front_paren == 0 && parenthesis == 0) return;
      if(front_paren != 0) flag = true; // signal changes at front.
      std::string result;
      result.resize(front_paren + input.size() + parenthesis);
      std::memset(&result[0], '(', front_paren);
      std::memcpy(&result[front_paren], &input[0], input.size());
      std::memset(&result[front_paren + input.size()], ')', parenthesis);
      input.swap(result);
    }

    // Cleans up unnecessary parentheses from a fully functionalized expression string.
    // This function assumes all operators have already been converted to functional form,
    // e.g., "5 + 7" → "add(5, 7)".
    // It targets parentheses that wrap around things without a preceding function name (like stray brackets),
    // removing redundant pairs without breaking the expression.
    //
    // Important:
    //   - Should be called **after** verifying balanced parentheses.
    //   - Does NOT handle operator symbols like '+' or '-' directly; those should already be replaced.
    //
    // How it works:
    //   - Uses a stack to track opening parentheses indices and whether they’re "potentially removable".
    //   - An opening parenthesis is marked as removable if it’s NOT preceded by a lowercase letter (function name).
    //   - When a closing parenthesis is found:
    //       - If the matching opening parenthesis was marked removable, erase both parentheses.
    //       - Otherwise, just pop the stack and move on.
    //   - If an error is detected (like empty stack or consecutive parentheses without content), flags an anomaly.
    //
    // Side effects:
    //   - Modifies the input string in place by removing redundant parentheses.
    //   - Updates error log and anomaly flag if improper parenthesis usage is found.
    void paren_cleaner(std::string &input) noexcept {
      std::string result;
      result.resize(input.size());
      char *k = &result[0], *t = k;
      const char *it = &input[0], *end = &input[input.size()], *it_o = it;
      int parenthesis = 0, result_parenthesis = 0;
      while(it != end) {
        switch(*it) {
          case'(':
            if(it != it_o && is_lower(*(it - 1))) {
              result_parenthesis++;
              *(k++) = '(';
            }
            parenthesis++;
            break;
          case')':
            if(parenthesis == result_parenthesis) {
              result_parenthesis--;
              *(k++) = ')';
            }
            parenthesis--;
            break;
          default:
            *(k++) = *it;
        }
        it++;
      }
      result.resize(k - t);
      input.swap(result);
    }

    // Helper function to clean up Unicode constants and symbols inside the input string.
    //
    // What it does:
    // - Replaces Unicode math symbols (like √, superscripts, etc.) with their ASCII equivalents or functional forms.
    // - Handles special constants like π (pi) and e (Euler’s number) and ensures they are replaced properly.
    // - Deals with superscript Unicode characters (e.g., ², ³) by converting them into "^" notation or inserting implicit multiplication "*" where needed.
    // - Carefully avoids breaking multi-byte Unicode sequences and ensures operators/constants are replaced in the right order.
    //
    // How it works:
    // - If Unicode is present:
    //     - Iterates over a conversion table of Unicode symbols and replaces each occurrence in the string.
    //     - Special case for the square root (√) symbol because it's multi-byte.
    // - Replaces occurrences of "pi" with an internal placeholder (`equal_str`).
    // - Replaces occurrences of "e" with another placeholder (`at_str`), avoiding cases where "exp" or trig functions like "cos" might be mistakenly replaced.
    // - Processes superscript characters by:
    //     - Converting them to "^" followed by the numeric character.
    //     - Adding multiplication symbols "*" before or after superscripts where appropriate (e.g., `2³4` → `2^3*4`).
    // - Uses a lambda (`pi_and_euler`) to handle placeholders insertion with careful multiplication insertion around them.
    // - Finally replaces certain ASCII castings that may still exist (based on `ascii_cast` array), accounting for multi-byte chars.
    //
    // Why this matters:
    // - Converts fancy Unicode math notation to simple, clean ASCII math strings that are easier to parse downstream.
    // - Ensures implicit multiplication (often missing in raw Unicode math strings) is correctly represented.
    void unicode_constant_cleanup(std::string &input) noexcept {
      std::string result;
      result.resize(input.size() << 1);
      const char *it = &input[0], *it_ = it, *end = it + input.size();
      char *k = &result[0], *t = k;
      while(it != end) {
        if(*it > 0) {
          switch(*it) {
            case'e': // exp, neg, sec, ceil, tangent, sine <- skip these ('e' appears nowhere else)
              if(it != it_ && is_invalid_precede_e(it - 1)) {
                *(k++) = *(it++);
                continue;
              }
              if(it + 2 < end && *(it + 1) == 'x' && *(it + 2) == 'p' && (it + 3 == end || *(it + 3) != 'i')) { // avoid exp and don't flag it with expi which is just e*x*pi.
                *(k++) = *(it++);
                continue;
              }
              if(k != t && is_lower(*(k - 1))) *(k++) = '*';
              *(k++) = *(it++);
              if(it != end && (is_lower(*it) || *it == '(')) *(k++) = '*';
              break;
            case'p':
              if(it + 1 != end && *(it + 1) == 'i') {
                if(k != t && is_lower(*(k - 1))) *(k++) = '*';
                *(k++) = *(it++);
                *(k++) = *(it++);
                if(it != end && (is_lower(*it) || *it == '(')) *(k++) = '*';
              }
              else *(k++) = *(it++);
              break;
            default:
              *(k++) = *(it++);
          }
        }
        else {
          int len = 2 + (*it == -30);
          if(is_superscript(it)){
            if((k != t && (is_lower(*(k - 1)) || *(k - 1) == ')')) || it != it_ && is_digit(*(it - 1)) || *it == '!') *(k++) = '^';
            *(k++) = superscript_to_ascci(it, len);
            if(it + len != end && is_digit(*(it + len))) *(k++) = '*';
          }
          else if(len == 3) *(k++) = '*';
          else if(*it != -49) {
            if(*(it) == -61 && *(it + 1) == -73) *(k++) = '/';
            else *(k++) = '*';
          }
          else {
            if(k != t && is_lower(*(k - 1))) *(k++) = '*';
            *(k++) = 'p';
            *(k++) = 'i';
            if(it + len != end && (is_lower(*(it + len)) || *(it + len) == '(')) *(k++) = '*'; 
          }
          it += len;
        }
      }
      result.resize(k - t);
      input.swap(result);
    }

    // Cleans up and normalizes the input string by:
    // - Calling the unicode_constant_cleanup() to handle Unicode symbols and constants.
    // - Normalizing sign sequences: multiple '+' and '-' characters in a row get simplified to a single '+' or '-'.
    // - Fixing decimal points by:
    //     - Adding a leading zero if decimal starts without a digit (".5" → "0.5").
    //     - Removing trailing or multiple consecutive decimals that don't make sense (e.g., "2...2" → "2.3").
    //
    // Why is this important?
    // - Makes sure expressions are consistent and easy to parse downstream by converting ambiguous or messy parts into neat, standard forms.
    // - Sign normalization helps avoid tricky bugs with multiple sign characters.
    // - Decimal fixes ensure the input won't confuse parsers or cause math errors.
    void basic_cleanup(std::string &input) noexcept {
      {
        std::string result; // Temporary string for single pass approach without replace or erase.
        int j;
        result.resize((input.length() << 1) - (input.length() >> 1)); // Theoretical max number of output size (e.g -> ".5" => 0.5; i.e, 1.5x).
        const char* it = &input[0], *end = it + input.length(); // Reading pointers.
        char *k = &result[0], *t = k; // Writing pointer and static pointer to the start.
        bool negative = false;
        while(it != end) { // Loop through the input.
          switch(*it) {
            case'+':
            case'-':
              negative = *(it++) == '-';
              while(it != end && is_sign(*it)) if(*(it++) == '-') negative = !negative; // Flip negative logic.
              if(k != t && is_sign(*(k - 1))) {
                // If the last written sign was '-' and the new sequence is also '-', make it '+' otherwise '-'
                // needed for cases like -.+-+ where it would become "--" instead of "+" without handling it explicitly.
                if(negative) *(k - 1) = *(k - 1) == '-' ? '+' : '-';
              }
              else *(k++) = negative ? '-' : '+'; // If the last written character wasn't a sign add the appropriate sign.
              break;
            case'.':
              if(it + 1 == end || !is_digit(*(it + 1))) {it++; continue;}
              if(k == t || !is_digit(*(k - 1))) // If the last output character wasn't a digit insert a 0.
                *(k++) = '0';
              *(k++) = *(it++); // Add the decimal point.
              j = 1;
              while(it + j != end && is_digit(*(it + j))) j++;
              std::memcpy(k, it, j);
              k += j;
              it += j;
              if(it != end && *it == '.') {
                this -> err_log = err_mul_dec;
                this -> anomaly = true;
                return;
              }
              break;
            default: *(k++) = *(it++); // Write the non-sign non-decimal character as-is.
          }
        }
        result.resize(k - t); // Resize to actual size.
        input.swap(result);
      }
      unicode_constant_cleanup(input);
    }

   // Replace every '#' character (which was a placeholder for '√') with 'sqrt()' function call.
    //
    // What it does:
    // - '#' is temporary stand-in for the square root symbol (√) because Unicode.
    // - This function scans the input string for all '#' characters and replaces each with "sqrt(".
    // - Then, it intelligently finds where to close the sqrt function with a matching ')' based on the expression that follows.
    //
    // How it works:
    // 1. Counts how many '#' characters are in the input.
    // 2. From the *right side* (because sqrt is right-associative here), finds each '#' one by one.
    // 3. Replaces the '#' with "sqrt(" (5 characters).
    // 4. Starting right after the inserted "sqrt(", scans forward to find the correct place to insert a closing ')' to wrap the operand inside sqrt.
    //    - It uses a "delimiter map" function (`primary_op_second_delimiter`) that tells whether a character is a delimiter (like +, -, *, /, ^, etc.).
    //    - The logic keeps track of parentheses to avoid prematurely closing sqrt if the operand is an expression inside parentheses.
    //    - It skips signs '+' or '-' immediately following the sqrt to avoid messing with expressions like `sqrt(-4)`.
    // 5. Inserts ')' either just before the next delimiter or at the end of the string if none is found.
    //
    // Also: By scanning from the right, it ensures nested sqrt calls work correctly, e.g., `##9` becomes `sqrt(sqrt(9))`, operator associativity.
    void add_sqrt(std::string &input) noexcept {

      // The delimiter check function (like +, -, *, /, ^, comma, or closing parenthesis).
      bool (*delimiter_map)(const unsigned char&) = &primary_op_second_delimiter;

      // How many sqrt placeholders are there?
      int count = std::count(input.begin(), input.end(), '#');
      int t = input.length() - 1;  // Start scanning from the end for right-to-left behavior.
      int parenthesis = 0;

      for(int i = 0; i < count; i++) {
        // Find the next '#' from the right side, moving leftward each time.
        int h;
        for(h = t + 1; h >= 0; h--)
          if(input[h] == '#') { t = h; break; }

        // Replace '#' with "sqrt("
        input.replace(t, 1, sqrt_func_str); // sqrt_func_str == "sqrt(".

        // After insertion, the new 'cursor' is at t + 5 (right after "sqrt(").
        t += 5;
        int j = t;

        // Find where to insert the closing ')'.
        for(; j < input.length(); j++) {
          if(delimiter_map(input[j]) && parenthesis == 0) {
            // If delimiter found and not inside parentheses, we want to close sqrt here.
            // Special cases:
            // - If delimiter is at the start and is a sign (+/-), ignore it to include negative numbers inside sqrt.
            if(j == t && is_sign(input[j])) continue;

            // - If just after the inserted sqrt, there's a '(' preceded by a sign, continue scanning.
            if(!(j == t + 1 && ((input[j] == '(') && is_sign(input[j - 1])))) break;
          }
          if(input[j] == '(') parenthesis++;
          else if(input[j] == ')') parenthesis--;
        }

        // Insert closing ')' at the found position or at the end if no delimiter found.
        if(j < input.size() - 1) {
          input.insert(j, close_paren); // close_paren == ")".
        }
        else {
          input += close_paren;
        }
      }
    }

    // Converts binary operators (like '^', '/', '*', '+', '-') in the input string
    // into a functional structure (e.g., "a^b" becomes "pow(a,b)").
    // This function respects operator precedence and associativity by processing
    // operators in a specific order (right-to-left for exponentiation, left-to-right for others).
    void binary_ops(std::string &input, const unsigned char &delimiter) noexcept {

      // Pointer to a function that determines valid delimiters for parsing.
      // Initially set to check for characters that would delimit the *first* operand.
      bool (*delimiter_map)(const unsigned char&) = &primary_op_first_delimiter;

      // Pointers to store the appropriate function name (e.g., "pow(", "div(")
      // and the corresponding error message string based on the current delimiter.
      const std::string *function, *error_name;
      // `check_hang` flag: true if the operator cannot stand alone without a left operand
      // (e.g., '*', '/', '^'). False for '+' and '-' which can be unary.
      bool check_hang = !is_sign(delimiter);

      // Initialize `function` and `error_name` based on the operator being processed.
      switch(delimiter) {
        case '^':
          function = &pow_func_str; error_name = &err_full_exp; break;
        case '/':
          function = &div_func_str; error_name = &err_full_div; break;
        case '*':
          function = &mul_func_str; error_name = &err_full_mul; break;
        case '-':
          function = &sub_func_str; error_name = &err_full_sub; break;
        case '+':
          function = &add_func_str; error_name = &err_full_add; break;
      }

      // Determine the starting index and direction for searching for the delimiter.
      // For exponentiation ('^'), process from right-to-left (due to right-associativity),
      // so start near the end of the string.
      // For other operators, process from left-to-right (left-associativity), start at the beginning.
      int index = delimiter == '^' ? input.length() - 2 : 0;
      // Count total occurrences of the delimiter to control the main loop iterations.
      int count = std::count(input.begin(), input.end(), delimiter);

      // Lambda function to determine the loop termination condition.
      // For '^', stop when index reaches 0 (or less). For others, stop at end of string.
      auto stop = [&]() -> size_t {
        return delimiter == '^' ? 0 : input.length();
      };
      // `update`: defines the step direction for searching (e.g., -1 for right-to-left, 1 for left-to-right).
      // `offset`: adjusts the starting point for the inner search loop based on the delimiter.
      int update = delimiter == '^' ? -1 : 1;
      int offset = delimiter == '^' ? 1 : 0; // Ensures starting search after the current `index` for left-to-right, or before for right-to-left.

      // Main loop: Iterates `count` times, processing one instance of the `delimiter` per iteration.
      for(int i = 0; i < count; i++) {

        // Inner loop: Finds the next occurrence of the `delimiter` in the string, respecting associativity.
        // It searches from `index + offset` up to `stop()` in the `update` direction.
        for(int j = index + offset; j != stop(); j += update) {
          if(input[j] == delimiter) {
            index = j; // Update `index` to the position of the found delimiter.
            break;     // Exit inner loop, as the delimiter is found.
          }
        }

        // Replace the found operator with a comma, marking the separation between arguments.
        input[index] = ',';

        // --- Handling Left Operand (First Argument) ---
        // Check if the character *before* the current operator (now a comma) is an invalid delimiter.
        // This helps identify "hanging" operators (e.g., `*2`, `+b`).
        if(index == 0 || (index > 0 && delimiter_map(input[index - 1]))) {

          // If the operator cannot have a missing first argument (e.g., `*`, `/`, `^`),
          // log an error and mark the expression as anomalous.
          if(check_hang) {
            this -> err_log = err_hanging;
            this -> err_log += *error_name;
            this -> err_log += err_operator;
            this -> anomaly = true;
            return; // Terminate processing due to error.
          }

          // Special handling for unary '+' operator: it can simply be removed.
          if(delimiter == '+') {
            if(input.size() == 1) {
              this -> err_log = err_no_func_op;
              this -> anomaly = true;
              return;
            }
            input.erase(index, 1); // Erase the comma (originally '+').
            index--;               // Adjust index due to removal.
            continue;              // Move to the next delimiter.
          }
          // Special handling for unary '-' operator: convert to "neg()" function.
          else {
            input.erase(index, 1); // Erase the comma (originally '-').
            index--;               // Adjust index due to removal.
            // Insert "neg(" at the correct position (before the operand).
            // If it was at the very beginning, insert at 0, otherwise at `index + 1`.
            input.insert(index > 0 ? index + 1 : 0, neg_func_str);
            index += 4; // Adjust `index` by the length of "neg(".
          }
        }
        // If it's not a standalone operator (has a left operand), find the insertion point
        // for the function name and insert it.
        else {
          int parenthesis = 0; // Counter for nested parentheses to ensure correct argument scope.
          int j = index - 1;   // Start searching left from the current comma.

          // Search backward to find the beginning of the left operand.
          // Stop if an opening delimiter is found *outside* any parentheses.
          for(; j > 0; j--) {
            if(delimiter_map(input[j]) && parenthesis == 0) break; // Found delimiter and not inside parens.
            if(input[j] == ')') parenthesis++;                     // Increment for closing parenthesis.
            else if(input[j] == '(') parenthesis--;                // Decrement for opening parenthesis.
          }
          // Insert the function name (e.g., "pow(", "mul(") at the calculated position.
          // If `j` is 0 or less, insert at the beginning of the string.
          input.insert(j <= 0 ? 0 : j + 1, *function);
          index += function -> length(); // Adjust `index` by the length of the inserted function name.
        }

        // --- Handling Right Operand (Second Argument) and Closing Parenthesis ---
        // After processing the left operand, switch the delimiter map to find characters
        // that would delimit the *second* operand (e.g., closing parenthesis, other operators).
        delimiter_map = &primary_op_second_delimiter;
    
        int j = index + 1;       // Start searching right from the current comma.
        int parenthesis = 0;     // Reset parenthesis counter for forward search.

        // Search forward to find the end of the right operand.
        // Stop if a closing delimiter is found *outside* any parentheses.
        for(; j < input.length(); j++) {
          if(delimiter_map(input[j]) && parenthesis == 0) {
            // Special case: if it's a non-sign operator and the next character is a sign,
            // it means the sign is part of the right operand (e.g., `2*-3`).
            // In this scenario, don't stop; continue searching.
            if(!is_sign(delimiter) && is_sign(input[j]) && j == index + 1) continue;
            break; // Found delimiter and not inside parens.
          }
          if(input[j] == ')') parenthesis--; // Decrement for closing parenthesis.
          else if(input[j] == '(') parenthesis++; // Increment for opening parenthesis.
        }

        // Error check: If the end of the right operand is immediately after the comma,
        // it indicates a trailing operator (e.g., `2+`), which is an error.
        if(j - index == 1 || index == input.length() - 1) {
          this -> err_log = err_trailing;
          this -> err_log += *error_name;
          this -> err_log += err_operator;
          this -> anomaly = true;
          return; // Terminate processing due to error.
        }
        // Insert the closing parenthesis ')' at the end of the right operand.
        else if(j < input.length()) { // If `j` is within string bounds, insert.
          input.insert(j, close_paren);
        }
        else { // If `j` is at the very end of the string, append.
          input += close_paren;
        }

        // Reset the delimiter map for the next iteration to find first operands again.
        delimiter_map = &primary_op_first_delimiter;
      }
    }

    void func_name_norm(std::string &input) noexcept {
      std::string result;
      result.resize(input.size());
      const char *it = &input[0], *end = &input[input.size()];
      char *k = &result[0], *t = k;
      while(it != end) {
        if(is_lower(*it)) {
          int j = 1;
          while((it + j != end) && is_lower(*(it + j))) j++;
          const std::string *sub = alias_normalisation(it, j);
          if(sub == &emp) {
            std::memcpy(k, it, j);
            k += j;
          }
          else for(const char &c : *sub) *(k++) = c;
          it += j;
        }
        else *(k++) = *(it++);
      }
      result.resize(k - t);
      input.swap(result);
    }

    // Transforms implicit multiplication in a mathematical expression string 
    // into explicit multiplication using '*'. 
    // For example, turns "2x" into "2*x", or "3(x+1)" into "3*(x+1)".
    void implicit_mult(std::string &input) noexcept {
      // '#' is placeholder for sqrt symbol.
      std::string result;
      result.resize(input.size() << 1);
      const char *it = &input[0], *end = it + input.size(), *it_ = it;
      char *k = &result[0], *t = k;
      while(it != end) {
        if(is_digit(*it)) {
          *(k++) = *(it++);
          if(it != end && (is_lower(*it) || *it == '(' || *it == '#')) *(k++) = '*';
        }
        else if(*it == 'x') {
          bool is_correct_precede = (k == t || !invalid_precede_x(*(k - 1)));
          *(k++) = *(it++);
          if(it != end && (is_correct_precede && (*it == '(' || is_low_num(*(it)) || *(it) == '#'))) *(k++) = '*';
        }
        else if(is_lower(*it)) {
          *(k++) = *(it++);
          if(it != end && (*it == '#' || is_digit(*it))) *(k++) = '*';
        }
        else if(*it == ')') {
          *(k++) = *(it++);
          if(it != end && (*it == '(' || is_low_num(*it) || *it == '#')) *(k++) = '*';
        }
        else if(*it == '!') {
          *(k++) = *(it++);
          if(it != end && (*it == '(' || is_low_num(*it) || *it == '#')) *(k++) = '*';
        }
        else *(k++) = *(it++);
      }
      result.resize(k - t);
      input.swap(result);
    }

    // Checks whether the input string contains any invalid characters.
    // Also detects if any Unicode characters are present.
    // Returns true if an invalid character is found; false otherwise.
    // Also normalising the input string by removing spaces and lowercasing all characters(alphabets, keeping everything as is).
    bool input_validation_normalisation(std::string &input) noexcept {
      std::string result;
      result.resize(input.size()); // Resize to maximum possible size.
      char *k = &result[0], *t = k; // Writing pointers.
      const char *it = &input[0], *end = it + input.size(); // Reading pointers.
      while(it != end) {
        if(((*it) & 0x80) == 0) { // Single byte ASCCI characters.
          if(is_space(*it)) it++;
          else {
            char c = to_lower(*(it++)); // Cannot directly check for valid characters before lowercasing potentially uppercase alphabets.
            if(is_valid_character(&c, 1)) *(k++) = c;
            else return true;
          }
        }
        else if(((*it) & 0xE0) == 0xC0) { // Two byte unicode characters.
          if(it + 2 > end) return true;
          else if(is_valid_character(it, 2)) {
            *(k++) = *(it++); // To avoid memcpy's overhead for just two bytes.
            *(k++) = *(it++);
          }
          else return true;
        }
        else if(((*it) & 0xF0) == 0xE0) { // Three byte unicode characters.
          if(it + 3 > end) return true;
          else if(is_valid_character(it, 3)) {
            std::memcpy(k, it, 3);
            k += 3;
            it += 3;
          }
          else return true;
        }
        else return true; // No 4 byte unicode are in valid character list.
      }
      result.resize(k - t); // Resize to actual size.
      input.swap(result);
      return false;
    }

    // Remove (), ()()(), (()()()), ((())) in a single pass(O(n), don't use abstraction methods like find & erase coz O(n*k)).
    // eg, (((()))A) -> (A), (()()()A) -> (A), ()A -> A, (AAA(A)()) -> (AAA(A)), (((A))) -> (((A))), ((()()()))((()))()()() -> _(nothing), (A()B) -> (AB).
    void remove_empt(std::string &input, bool &flag) noexcept {
      int parenthesis = 0, result_parenthesis = 0; // stack like counters for input parenthesis and output parenthesis.
      std::string result;
      result.resize(input.size());
      char *k = &result[0], *t = k;
      const char *it = &input[0], *end = &input[input.size()];
      while(it != end) {
        switch(*it) {
          case'(':
            parenthesis++;
            break;
          case')':
            if(parenthesis == result_parenthesis) {
              *(k++) = *it;
              result_parenthesis--;
            }
            parenthesis--;
            break;
          default:
            int difference = parenthesis - result_parenthesis;
            std::memset(k, '(', difference);
            result_parenthesis = parenthesis; // update to sync.
            k += difference;
            const char *it_1 = (char*)std::memchr(it, '(', end - it), *it_2 = (char*)std::memchr(it, ')', end - it), *it_ = nullptr; // find the next parenthesis.
            // set it_ to the closest pointer.
            if(it_1 == NULL && it_2 == NULL) it_ = end;
            else if(it_1 == NULL) it_ = it_2;
            else if(it_2 == NULL) it_ = it_1;
            else it_ = (it_1 < it_2 ? it_1 : it_2);
            std::memmove(k, it, it_ - it); // move everything before the next parenthesis.
            k += it_ - it; // update the output buffer.
            it = it_ - 1; // -1 because main loop increments by 1.
        }
        it++;
      }
      result.resize(k - t); // resize to actual size.
      flag = true;
      input.swap(result);
    }

    // Convert implicit factorial symbols ('!') into explicit function calls (e.g., ftrl()).
    // Also performs error checks for invalid placements of the factorial operator.
    void factorial_convert(std::string &input) noexcept {
      // Find the first occurrence of the '!' character.
      size_t t = input.find('!');

      // Error: '!' at the very beginning is invalid as there's nothing to apply it to.
      if(t == 0) {
        this -> err_log = invalid_fact_place;
        this -> anomaly = true;
        return;
      }

      // Process all occurrences of '!' in the input string.
      while (t != std::string::npos) {
        int parenthesis = 0;
        int i = t - 1;

        // Error: If the character before '!' is an operator or an opening parenthesis,
        // there's no valid operand for the factorial.
        if(is_op(input[t - 1]) || input[t - 1] == '(') {
          this -> err_log = err_no_arg_fact;
          this -> anomaly = true;
          return;
        }

        // Replace the '!' with a closing parenthesis for the explicit function call.
        input[t] = ')';

        // Walk backwards to find the beginning of the factorial's operand.
        for (; i >= 0; i--) {

          // Handle nested parentheses correctly.
          if(input[i] == '(') {
            if(parenthesis == 0) break;
            parenthesis--;
            if(parenthesis < 0) {
              // More closing than opening parens while walking back — invalid structure.
              this -> err_log = err_incorrect_paren_use;
              this -> anomaly = true;
              return;
            }
          }

          // Stop at beginning or at an operator, if parentheses are balanced.
          else if(i == 0 || is_op(input[i])) {
            if(parenthesis == 0) {
              break;
            }
            else {
              // Found an operator while parentheses were still open — invalid location.
              this -> err_log = invalid_fact_place;
              this -> anomaly = true;
              return;
            }
          }

          // Track opening of a nested expression.
          else if(input[i] == ')') {
            parenthesis++;
          }
        }

        // Insert the "ftrl(" function call before the operand.
        // If i == 0, insert at the beginning. Otherwise, insert right after the relevant operator or parenthesis.
        input.insert(i == 0 ? 0 : i + 1, ftrl_func_str);

        // Move to the next '!' occurrence. Adjust by +4 to skip over the just-inserted "ftrl(".
        t = input.find('!', t + 4);
      }
    }

    // Validates the correct usage of commas within binary functions in a given input string.
    // Ensures commas only appear where they logically belong (i.e., within binary functions).
    void valid_commas(const std::string &input) noexcept {

      std::string temp; // Temporarily holds function names or variables being built character by character.
      int parenthesis = 0; // Tracks the current depth of nested parentheses.

      // Stack holds pairs: 
      //   - the parenthesis depth when a binary function starts,
      //   - a bool flag to track if a comma has been seen inside that function's arguments.
      std::stack<std::pair<int, bool>> parenthesis_count;

      for(int i = 0; i < input.size(); i++) {
        if(is_lower(input[i])) {
          // Collect lowercase letters into 'temp' to form potential function names.
          temp += input[i];
        }
        else {
          if(input[i] == '(') {
            // If we just finished reading a binary function name...
            if(!temp.empty() && is_binary_func(temp)) {
              // Push the current parenthesis depth and a "comma-not-yet-found" flag.
              parenthesis_count.push({parenthesis, false});
            }
            parenthesis++; // We just opened a parenthesis, diving deeper!
          }
          else if(input[i] == ')') {
            parenthesis--; // Coming back up a level of nesting.

            // If we have more closing parens than opening: oops!
            if(parenthesis < 0) {
              this -> err_log = err_incorrect_paren_use;
              this -> anomaly = true;
              return;
            }

            // Check if we're closing a binary function's parentheses.
            if(!parenthesis_count.empty() && parenthesis_count.top().first == parenthesis) {
              // If no comma was found inside a binary function: that's a problem.
              if(!parenthesis_count.top().second) {
                this -> err_log = err_no_comma;
                this -> anomaly = true;
                return;
              }
              parenthesis_count.pop(); // Remove this function from the stack.
            }
          }
          else if(input[i] == ',') {
            // Check if we are even inside a binary function at all.
            if(parenthesis_count.empty() || parenthesis_count.top().first != parenthesis - 1) {
              this -> err_log = err_used_comma; // Rogue comma with no binary function.
              this -> anomaly = true;
              return;
            }

            // A second comma in the same binary function.
            if(parenthesis_count.top().second) {
              this -> err_log = err_mul_comma;
              this -> anomaly = true;
              return;
            }

            // Ensure the comma is not preceded by an operator or other junk.
            if((i == 0) || is_invalid_precedence(input[i - 1])) {
              this -> err_log = err_no_first_arg; // Comma with no first argument? That's suspicious.
              this -> anomaly = true;
              return;
            }

            // Ensure the comma is not followed by an operator or invalid symbol.
            if((i == input.size() - 1) || is_invalid_subsidence(input[i + 1])) {
              this -> err_log = err_no_second_arg; // Comma with no second argument? Even more suspicious.
              this -> anomaly = true;
              return;
            }

            // Mark that we've seen a valid comma inside this binary function.
            parenthesis_count.top().second = true;
          }

          temp.clear(); // Reset temp since we're done processing a token.
        }
      }
    }

  // Friend operators / convinience functions.
  public:

    // This function provides a formatted output of the expression,
    // including its original, modified, and status details.
    void print(std::ostream &os) const noexcept {
      // Output the original expression, prefixed with a descriptive string.
      os << fp_org_str << this -> entered_expression;
      // Output a separator or introductory string for the modified expression.
      os << fp_mod_str;
      // Check if an anomaly was detected and if the modified expression contains parentheses.
      // If no anomaly and parentheses are present, format the output for readability.
      if(!anomaly && this -> modified_expression.find(open_paren) != std::string::npos) {
        os << '\n'; // Add a newline for better formatting of the structured output.
        int parenthesis = 0; // Initialize a counter for parenthesis nesting level.
        std::string string = this -> modified_expression; // Create a local copy of the modified expression.
        // Iterate through each character of the modified expression.
        for(int i = 0; i < string.size(); i++) {
          // If an opening parenthesis is encountered,
          // print it, increment the nesting level, and indent the next line.
          if(string[i] == '(') {
            os << string[i] << '\n';
            parenthesis++;
            os << std::string(2 * parenthesis, ' '); // Indent based on nesting level.
          }
          // If a closing parenthesis is encountered,
          // decrement the nesting level and print it with appropriate indentation.
          else if(string[i] == ')') {
            parenthesis--;
            // If the parenthesis counter drops below zero, it indicates a mismatch (e.g., too many closing parentheses).
            if(parenthesis < 0) {
              os << '\n' << unexpected_error << '\n'; // Output an unexpected error message.
              break; // Exit the loop due to the error.
            }
            os << '\n' << std::string(2 * parenthesis, ' ') << string[i]; // Print with adjusted indentation.
          }
          // If a comma is encountered, print it and then indent the next line.
          else if(string[i] == ',') {
            os << string[i] << '\n' << std::string(2 * parenthesis, ' ');
          }
          // For any other character, print it directly.
          else os << string[i];
        }
      }
      // If an anomaly was detected or no parentheses are present, print the modified expression directly without special formatting.
      else os << this -> modified_expression;
      // Output the status of the expression, indicating if an anomaly was detected.
      // If an anomaly exists and it's not "not modified", print an empty string; otherwise, print "no anomaly".
      os << fp_status_str << ((anomaly && this -> err_log != err_not_modified) ? empty_string : fp_no_str) << fp_anomaly_detected;
      // Output the error log, which provides details about any detected anomalies or issues.
      os << fp_log_str << this -> err_log << '\n';
    }

    // Output stream operator to print all the useful information.
    friend std::ostream &operator<<(std::ostream &os, const expression &obj) {
      obj.print(os);
      return os;
    }

    // Provide the result string of result of the object.
    friend const std::string &operator<<(std::string &str, const expression &obj) {
      str = obj.result();
      return str;
    }

    // Provide the parsed expression in a object.
    friend const expression &operator<<(expression &obj, const std::string &str) {
      obj.update(str);
      return obj;
    }

    // To parse a input directly from input stream.
    friend std::istream &operator>>(std::istream &is, expression &obj) {
      std::string line;
      std::getline(is, line);
      obj.update(line);
      return is;
    }

    // Provide the string of what the result of the object is.
    friend const expression &operator>>(const expression &obj, std::string &str) {
      str = obj.result();
      return obj;
    }

    // Parse a string and extract in the object.
    friend const std::string &operator>>(const std::string &str, expression &obj) {
      obj.update(str);
      return str;
    }

  // Private data members.
  protected:
    std::string entered_expression;
    std::string modified_expression;
    bool anomaly = true;
    bool allow_variable = true;
    std::string err_log = err_not_modified;
};

