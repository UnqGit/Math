    // Transforms implicit multiplication in a mathematical expression string 
    // into explicit multiplication using '*'. 
    // For example, turns "2x" into "2*x", or "3(x+1)" into "3*(x+1)".
    void implicit_mult(std::string &input) noexcept {

      // Loop through each character in the input string
      for(int i = 0; i < input.length(); i++) {

        // --------- Rule for square root symbol '#' ---------
        if(input[i] == '#') {

          // If the '#' is preceded by a valid character (e.g. number, variable, etc.),
          // and not by '(' or another '#', insert '*' before the '#'.
          if(i > 0 && implicit_mult_valid_char_find(input[i - 1]) &&
             !(input[i - 1] == '(' || input[i - 1] == '#')) {
            input.insert(i, asterisk_str); // insert '*'
            i++; // advance to skip the inserted '*'
          }

          // Error check: if '#' is immediately followed by ')', it's a syntax error
          if((i + 1) < input.size() && input[i + 1] == ')') {
            this -> err_log = err_paren_no_arg;
            this -> anomaly = true;
            return;
          } 
        }

        // --------- Rule for variable 'x' ---------
        else if(input[i] == 'x') {

          // Skip if 'x' is preceded by an invalid character
          if(i > 0 && invalid_precede_x(input[i - 1])) continue;

          // If 'x' is preceded by a valid character (e.g. number or closing paren)
          // and not by '(' or '#', insert '*' before 'x'
          if(i > 0 && implicit_mult_valid_char_find(input[i - 1]) &&
             !(input[i - 1] == '(' || input[i - 1] == '#')) {
            input.insert(i, asterisk_str);
            i++; // move past inserted '*'
          }

          // If 'x' is followed by a lowercase letter (e.g. a function),
          // or valid character (but not ')' or '!'), insert '*' after 'x'
          if((i + 1) < input.length() && 
             (is_lower(input[i + 1]) || 
             (implicit_mult_valid_char_find(input[i + 1]) && 
             (input[i + 1] != ')' && input[i + 1] != '!')))) {
            input.insert(i + 1, asterisk_str);
          }
        }

        // --------- Rule for functions (e.g. sin, cos, log) ---------
        else if(is_lower(input[i])) {
          // If a function name starts immediately after a digit or ')',
          // insert '*' before the function name
          if(i > 0 && (std::isdigit(input[i - 1]) || input[i - 1] == ')')) {
            input.insert(i, asterisk_str);
            i++; // skip past the inserted '*'
          }
        }

        // --------- Rule for factorial symbol '!' ---------
        else if(input[i] == '!') {
          // If '!' is immediately followed by a digit or letter, insert '*' after it
          if((i + 1) < input.size() && std::isalnum(input[i + 1])) {
            input.insert(i + 1, asterisk_str);
          }
        }

        // --------- Rule for opening parenthesis '(' ---------
        else if(input[i] == '(') {
          // If '(' is preceded by a valid character (not '(' or '#'), insert '*' before it
          if(i > 0 && implicit_mult_valid_char_find(input[i - 1]) &&
             !(input[i - 1] == '(' || input[i - 1] == '#')) {
            input.insert(i, asterisk_str);
            i++; // move past inserted '*'
          }

          // Error check: if '(' is immediately followed by ')', it's a syntax error
          if((i + 1) < input.size() && input[i + 1] == ')') {
            this -> err_log = err_paren_no_arg;
            this -> anomaly = true;
            return;
          } 
        }

        // --------- Rule for closing parenthesis ')' ---------
        else if(input[i] == ')') {
          // If ')' is followed by a valid character (not ')' or '!'), insert '*' after it
          if((i + 1) < input.length() && implicit_mult_valid_char_find(input[i + 1]) &&
             !(input[i + 1] == ')' || input[i + 1] == '!')) {
            input.insert(i + 1, asterisk_str);
          }
        }
      }
    }

    // Checks whether the input string contains any invalid characters.
    // Also detects if any Unicode characters are present.
    // Returns true if an invalid character is found; false otherwise.
    bool input_validation_normalisation(std::string &input, bool &is_unicode_present) noexcept {
      std::string result;
      result.resize(input.size());
      char *k = &result[0], *t = k;
      const char *it = &input[0], *end = &input[input.size()];
      while(it != end) {
        if(((*it) & 0x80) == 0) {
          if(is_space(*it)) it++;
          else {
            char c = to_lower(*(it++));
            if(is_valid_character(&c, 1)) *(k++) = c;
            else return true;
          }
        }
        else if(((*it) & 0xE0) == 0xC0) {
          if(it + 2 >= end) return true;
          else if(is_valid_character(it, 2)) {
            is_unicode_present = true;
            *(k++) = *(it++);
            *(k++) = *(it++);
          }
          else return true;
        }
        else if(((*it) & 0xF0) == 0xE0) {
          if(it + 3 >= end) return true;
          else if(is_valid_character(it, 3)) {
            is_unicode_present = true;
            std::memcpy(k, it, 3);
            k += 3;
            it += 3;
          }
          else return true;
        }
        else return true;
      }
      result.resize(k - t);
      input.swap(result);
      return false;
    }

    // Remove (), ()()(), (()()()), ((())) in a single pass(O(n), don't use abstraction methods like find & erase coz O(n*k)).
    // eg, (((()))A) -> (A), (()()()A) -> (A), ()A -> A, (AAA(A)()) -> (AAA(A)), (((A))) -> (((A))), ((()()()))((()))()()() -> _(nothing), (A()B) -> (AB).
    void remove_empt(std::string &input, bool &flag) noexcept {
      int parenthesis = 0, result_parenthesis = 0; // stack like counters for input parenthesis and output parenthesis.
      std::string result;
      result.resize(input.size());
      char *k = &result[0], *t = k;
      const char *it = &input[0], *end = &input[input.size()];
      while(it != end) {
        switch(*it) {
          case'(':
            parenthesis++;
            break;
          case')':
            if(parenthesis == result_parenthesis) {
              *(k++) = *it;
              result_parenthesis--;
            }
            parenthesis--;
            break;
          default:
            int difference = parenthesis - result_parenthesis;
            std::memset(k, '(', difference);
            result_parenthesis = parenthesis; // update to sync.
            k += difference;
            const char *it_1 = (char*)std::memchr(it, '(', end - it), *it_2 = (char*)std::memchr(it, ')', end - it), *it_ = nullptr; // find the next parenthesis.
            // set it_ to the closest pointer.
            if(it_1 == NULL && it_2 == NULL) it_ = end;
            else if(it_1 == NULL) it_ = it_2;
            else if(it_2 == NULL) it_ = it_1;
            else it_ = (it_1 < it_2 ? it_1 : it_2);
            std::memmove(k, it, it_ - it); // move everything before the next parenthesis.
            k += it_ - it; // update the output buffer.
            it = it_ - 1; // -1 because main loop increments by 1.
        }
        it++;
      }
      result.resize(k - t); // resize to actual size.
      flag = true;
      input.swap(result);
    }

    // Checks for various forms of inappropriate operator usage and flags errors accordingly.
    // This function aims to catch syntax errors related to operator placement (e.g., hanging operators,
    // operators without arguments, consecutive operators).
    void malform_ops(std::string &input) noexcept {

      // --- Initial Checks ---

      // Flag an error immediately if the input expression is empty.
      if(input.empty()) {
        this -> err_log = err_no_expression; // Set error message for empty input.
        this -> anomaly = true;              // Mark the expression as invalid.
        return;
      }

      // Flag an error if the entire expression consists of a single primary operator.
      // E.g., "+", "*", "/", etc. (unary signs are handled later if part of a larger expression).
      if(input.size() == 1 && is_primary_ops(input.front())) {
        this -> err_log = err_no_func_op; // Set error message for a lone operator.
        this -> anomaly = true;
        return;
      }

      // --- Iterative Checks for Operator Malformations ---

      // Loop through each character in the input string to check for operator-related errors.
      for(int i = 0; i < input.length(); i++) {

        // Redundant but safe check: Flag empty parentheses like "()".
        // This is often handled by `implicit_mult` but included here for robustness.
        if(input[i] == '(' && (i + 1) < input.length() && input[i + 1] == ')') {
          this -> err_log = err_paren_no_arg; // Error for parentheses with no arguments.
          this -> anomaly = true;
          return;
        }

        // Check if the current character is one of the primary mathematical operators.
        if(is_primary_ops(input[i])) {

          // Handle unary plus sign at the very beginning of the expression.
          if(i == 0 && input[i] == '+') {
            if(input.size() != 1) { // If it's not a lone '+' (already handled above), remove it.
              input.erase(i, 1);
              i--; // Decrement 'i' to re-evaluate the character now at this position.
              continue; // Move to the next iteration.
            }
            else { // If it's a lone '+', it's an error.
              this -> err_log = err_no_func_op; // Set error for a lone operator.
              this -> anomaly = true;
              return;
            }
          }

          // Check operator placement if it's not at the very beginning of the expression.
          if(i > 0) {
            // Error check: Operator immediately after an opening parenthesis, unless it's a unary minus.
            // E.g., "(+5)" is fine, "(*5)" is not.
            if(input[i - 1] == '(' && input[i] != '-') {
              if(input[i] == '+') { // Remove unary '+' inside parentheses.
                input.erase(i, 1);
                i--;
                continue;
              }
              this -> err_log = err_han_op_paren; // Error for hanging operator after an open parenthesis.
              this -> anomaly = true;
              return;
            }

            // Check operator placement if it's not at the very end of the expression.
            if((i + 1) < input.size()) {
              // Error check: Operator immediately before a closing parenthesis.
              // E.g., "5+)" is an error.
              if(input[i + 1] == ')') {
                this -> err_log = err_trl_op_paren; // Error for trailing operator before a close parenthesis.
                this -> anomaly = true;
                return;
              }
              // Check for consecutive primary operators.
              // E.g., "5**2", "5/+" etc.
              else if(is_primary_ops(input[i + 1])) {
                if(input[i + 1] == '+') { // If the next operator is a '+', remove it. E.g., "5*+2" becomes "5*2".
                  input.erase(i + 1, 1);
                  i--; // Decrement 'i' to re-evaluate the current position (after deletion).
                  continue;
                }
                // Allow cases like "5*-2" (minus as a unary sign) if the current operator is not a sign.
                // E.g., "2+-3" becomes "2-3" (handled by basic_cleanup).
                else if(!is_sign(input[i]) && input[i + 1] == '-') {
                  continue;
                }
                else { // Any other consecutive primary operators are errors. E.g., "5**2", "5//2".
                  this -> err_log = err_mal_op; // Error for malformed (consecutive) operators.
                  this -> anomaly = true;
                  return;
                }
              }
            }
            // Error check: Trailing operator at the end of the expression (e.g., "5+").
            else {
              this -> err_log = err_tr_op; // Error for a trailing operator at end of expression.
              this -> anomaly = true;
              return;
            }
          }
          // Error check: Hanging operator at the start of the expression, if it's not a unary sign.
          // E.g., "*5", "/2". Also catches cases like "++5" or "-+5" if `is_sign` handles those.
          else if(!is_sign(input[i]) || ((i + 1) < input.length() && is_sign(input[i + 1]))) {
            this -> err_log = err_han_op; // Error for a hanging operator at start of expression.
            this -> anomaly = true;
            return;
          }
        }
      }
    }

    // Convert implicit factorial symbols ('!') into explicit function calls (e.g., ftrl()).
    // Also performs error checks for invalid placements of the factorial operator.
    void factorial_convert(std::string &input) noexcept {
      // Find the first occurrence of the '!' character.
      size_t t = input.find(exclaimation);

      // Error: '!' at the very beginning is invalid as there's nothing to apply it to.
      if(t == 0) {
        this -> err_log = invalid_fact_place;
        this -> anomaly = true;
        return;
      }

      // Process all occurrences of '!' in the input string.
      while (t != std::string::npos) {
        int parenthesis = 0;
        int i = t - 1;

        // Error: If the character before '!' is an operator or an opening parenthesis,
        // there's no valid operand for the factorial.
        if(is_op(input[t - 1]) || input[t - 1] == '(') {
          this -> err_log = err_no_arg_fact;
          this -> anomaly = true;
          return;
        }

        // Replace the '!' with a closing parenthesis for the explicit function call.
        input[t] = ')';

        // Walk backwards to find the beginning of the factorial's operand.
        for (; i >= 0; i--) {

          // Handle nested parentheses correctly.
          if(input[i] == '(') {
            if(parenthesis == 0) break;
            parenthesis--;
            if(parenthesis < 0) {
              // More closing than opening parens while walking back — invalid structure.
              this -> err_log = err_incorrect_paren_use;
              this -> anomaly = true;
              return;
            }
          }

          // Stop at beginning or at an operator, if parentheses are balanced.
          else if(i == 0 || is_op(input[i])) {
            if(parenthesis == 0) {
              break;
            }
            else {
              // Found an operator while parentheses were still open — invalid location.
              this -> err_log = invalid_fact_place;
              this -> anomaly = true;
              return;
            }
          }

          // Track opening of a nested expression.
          else if(input[i] == ')') {
            parenthesis++;
          }
        }

        // Insert the "ftrl(" function call before the operand.
        // If i == 0, insert at the beginning. Otherwise, insert right after the relevant operator or parenthesis.
        input.insert(i == 0 ? 0 : i + 1, ftrl_func_str);

        // Move to the next '!' occurrence. Adjust by +4 to skip over the just-inserted "ftrl(".
        t = input.find(exclaimation, t + 4);
      }
    }

    // Validates the correct usage of commas within binary functions in a given input string.
    // Ensures commas only appear where they logically belong (i.e., within binary functions).
    void valid_commas(const std::string &input) noexcept {

      std::string temp; // Temporarily holds function names or variables being built character by character.
      int parenthesis = 0; // Tracks the current depth of nested parentheses.

      // Stack holds pairs: 
      //   - the parenthesis depth when a binary function starts,
      //   - a bool flag to track if a comma has been seen inside that function's arguments.
      std::stack<std::pair<int, bool>> parenthesis_count;

      for(int i = 0; i < input.size(); i++) {
        if(is_lower(input[i])) {
          // Collect lowercase letters into 'temp' to form potential function names.
          temp += input[i];
        }
        else {
          if(input[i] == '(') {
            // If we just finished reading a binary function name...
            if(!temp.empty() && is_binary_func(temp)) {
              // Push the current parenthesis depth and a "comma-not-yet-found" flag.
              parenthesis_count.push({parenthesis, false});
            }
            parenthesis++; // We just opened a parenthesis, diving deeper!
          }
          else if(input[i] == ')') {
            parenthesis--; // Coming back up a level of nesting.

            // If we have more closing parens than opening: oops!
            if(parenthesis < 0) {
              this -> err_log = err_incorrect_paren_use;
              this -> anomaly = true;
              return;
            }

            // Check if we're closing a binary function's parentheses.
            if(!parenthesis_count.empty() && parenthesis_count.top().first == parenthesis) {
              // If no comma was found inside a binary function: that's a problem.
              if(!parenthesis_count.top().second) {
                this -> err_log = err_no_comma;
                this -> anomaly = true;
                return;
              }
              parenthesis_count.pop(); // Remove this function from the stack.
            }
          }
          else if(input[i] == ',') {
            // Check if we are even inside a binary function at all.
            if(parenthesis_count.empty() || parenthesis_count.top().first != parenthesis - 1) {
              this -> err_log = err_used_comma; // Rogue comma with no binary function.
              this -> anomaly = true;
              return;
            }

            // A second comma in the same binary function.
            if(parenthesis_count.top().second) {
              this -> err_log = err_mul_comma;
              this -> anomaly = true;
              return;
            }

            // Ensure the comma is not preceded by an operator or other junk.
            if((i == 0) || is_invalid_precedence(input[i - 1])) {
              this -> err_log = err_no_first_arg; // Comma with no first argument? That's suspicious.
              this -> anomaly = true;
              return;
            }

            // Ensure the comma is not followed by an operator or invalid symbol.
            if((i == input.size() - 1) || is_invalid_subsidence(input[i + 1])) {
              this -> err_log = err_no_second_arg; // Comma with no second argument? Even more suspicious.
              this -> anomaly = true;
              return;
            }

            // Mark that we've seen a valid comma inside this binary function.
            parenthesis_count.top().second = true;
          }

          temp.clear(); // Reset temp since we're done processing a token.
        }
      }
    }

    // This function validates the format of decimal numbers within a given string.
    // It checks for various common decimal formatting errors to ensure data integrity.
    void invalid_decimal(const std::string &input) noexcept {

      // Check for an empty input string. An empty string is considered an invalid decimal format.
      if(input.empty()) {
        this -> err_log = err_empty_string;
        this -> anomaly = true;
        return;
      }

      // Locate the first occurrence of the decimal point character.
      size_t t = input.find(dot);

      // If a decimal point is found at the very beginning of the string (e.g., ".5"),
      // it is considered an invalid format.
      if(t == 0) {
        this -> err_log = err_hanging_dec;
        this -> anomaly = true;
        return;
      }

      // Iterate through all occurrences of decimal points within the string.
      while(t != std::string::npos) {

        // Verify that the character immediately preceding the decimal point is a digit.
        // For example, "+.5" or "(.7" would be flagged as invalid.
        if(!std::isdigit(input[t - 1])) {
          this -> err_log = err_dec_not_follows;
          this -> anomaly = true;
          return;
        }

        // Ensure that there are characters following the decimal point.
        if(t < input.length()) {

          // Confirm that the character immediately following the decimal point is a digit.
          // Examples like "3." or "4.a" would be considered invalid.
          if(!std::isdigit(input[t + 1])) {
            this -> err_log = err_dec_not_followed;
            this -> anomaly = true;
            return;
          }

          else {
            int j = 1;

            // Advance 'j' past all consecutive digits following the current decimal point.
            while((t + j) < input.length() && std::isdigit(input[t + j])) j++;

            // After processing the digits, check if there are more characters in the string.
            if((t + j) < input.length()) {

              // If the next character found after the sequence of digits is another decimal point,
              // it indicates multiple decimal points within a single number, which is invalid.
              if(input[t + j] == '.') {
                // Differentiate between a trailing decimal point (e.g., "12.3.
                // ") and multiple decimal points within the number (e.g., "1.2.3").
                this -> err_log = ((t + j == input.length() - 1) ? err_trailing_dec
                : err_mul_dec);
                this -> anomaly = true;
                return;
              }
            }
    
            // If no invalid conditions are met, and only digits follow the decimal point until the end of the string,
            // the current decimal point is considered valid in its context.
            else return;
          }
        }
    
        // Search for the next occurrence of a decimal point, starting from the character
        // immediately after the current one, to continue validation.
        t = input.find(dot, t + 1);
      }
    }

  // Friend operators / convinience functions.
  public:

    // This function provides a formatted output of the expression,
    // including its original, modified, and status details.
    void print(std::ostream &os) const noexcept {
      // Output the original expression, prefixed with a descriptive string.
      os << fp_org_str << this -> entered_expression;
      // Output a separator or introductory string for the modified expression.
      os << fp_mod_str;
      // Check if an anomaly was detected and if the modified expression contains parentheses.
      // If no anomaly and parentheses are present, format the output for readability.
      if(!anomaly && this -> modified_expression.find(open_paren) != std::string::npos) {
        os << '\n'; // Add a newline for better formatting of the structured output.
        int parenthesis = 0; // Initialize a counter for parenthesis nesting level.
        std::string string = this -> modified_expression; // Create a local copy of the modified expression.
        // Iterate through each character of the modified expression.
        for(int i = 0; i < string.size(); i++) {
          // If an opening parenthesis is encountered,
          // print it, increment the nesting level, and indent the next line.
          if(string[i] == '(') {
            os << string[i] << '\n';
            parenthesis++;
            os << std::string(2 * parenthesis, ' '); // Indent based on nesting level.
          }
          // If a closing parenthesis is encountered,
          // decrement the nesting level and print it with appropriate indentation.
          else if(string[i] == ')') {
            parenthesis--;
            // If the parenthesis counter drops below zero, it indicates a mismatch (e.g., too many closing parentheses).
            if(parenthesis < 0) {
              os << '\n' << unexpected_error << '\n'; // Output an unexpected error message.
              break; // Exit the loop due to the error.
            }
            os << '\n' << std::string(2 * parenthesis, ' ') << string[i]; // Print with adjusted indentation.
          }
          // If a comma is encountered, print it and then indent the next line.
          else if(string[i] == ',') {
            os << string[i] << '\n' << std::string(2 * parenthesis, ' ');
          }
          // For any other character, print it directly.
          else os << string[i];
        }
      }
      // If an anomaly was detected or no parentheses are present, print the modified expression directly without special formatting.
      else os << this -> modified_expression;
      // Output the status of the expression, indicating if an anomaly was detected.
      // If an anomaly exists and it's not "not modified", print an empty string; otherwise, print "no anomaly".
      os << fp_status_str << ((anomaly && this -> err_log != err_not_modified) ? empty_string : fp_no_str) << fp_anomaly_detected;
      // Output the error log, which provides details about any detected anomalies or issues.
      os << fp_log_str << this -> err_log << '\n';
    }

    // Output stream operator to print all the useful information.
    friend std::ostream &operator<<(std::ostream &os, const expression &obj) {
      obj.print(os);
      return os;
    }

    // Provide the result string of result of the object.
    friend const std::string &operator<<(std::string &str, const expression &obj) {
      str = obj.result();
      return str;
    }

    // Provide the parsed expression in a object.
    friend const expression &operator<<(expression &obj, const std::string &str) {
      obj.update(str);
      return obj;
    }

    // To parse a input directly from input stream.
    friend std::istream &operator>>(std::istream &is, expression &obj) {
      std::string line;
      std::getline(is, line);
      obj.update(line);
      return is;
    }

    // Provide the string of what the result of the object is.
    friend const expression &operator>>(const expression &obj, std::string &str) {
      str = obj.result();
      return obj;
    }

    // Parse a string and extract in the object.
    friend const std::string &operator>>(const std::string &str, expression &obj) {
      obj.update(str);
      return str;
    }

  // Private data members.
  protected:
    std::string entered_expression = empty_string;
    std::string modified_expression = empty_string;
    bool anomaly = true;
    bool allow_variable = true;
    std::string err_log = err_not_modified;
};

