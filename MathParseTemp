  bool is_binary_func(const std::string &input) {
    const size_t &length = input.length();
    unsigned int index;
    switch(length) {
      case 3:
      case 4:
        index = -103 + (input[0]^3 + input[1]^4 + input.back()^2);
        return index < 22 && std::memcmp(b_flt[index], &input[0], length) == 0;
      default:
        return false;
    }
  }

