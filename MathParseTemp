// Specialized lookup and validation utilities for parsing expressions.
//
// These are hand-optimized over generic unordered_set/hashmap equivalents
// using fixed-size lookup tables and bit hacks. If you want to add functionality,
// update the hash logic and tables as per YOUR addition
// or comment this scope and uncomment the above namespace and all the commented out
// usage of the above scope's unordered sets.
namespace {

  unsigned char to_lower(const unsigned char &c) {
    return (c > 64 && c < 91) ? c + 32 : c;
  }
  
  bool is_space(const unsigned char &c) {
    return c == 32 || c == 9 || c == 10;
  }

  bool is_lower(const char &c) noexcept {
    return c > 96 && c < 123;
  }

  // These were found by brute force to get the best results, no need to look in here.

  // ======= Lookup utilities for parsing and validation ======= //

  // Used in valid_commas(): defines invalid characters that shouldn't precede a comma.
  // Indexed by (char % 8). We rely on this cheap modulo hash to verify character category.
  constexpr char i_prec[8] {'(','\0','*','+',',','-','^','/'};
  constexpr bool is_invalid_precedence(const unsigned char &input) {
    return input == i_prec[input % 8];
  }

  // Alias used in factorial_convert() to check for operator characters.
  constexpr bool (*is_op)(const unsigned char&) = &is_invalid_precedence;

  // Determines if a character before 'x' makes it invalid (e.g., "exp" vs "x").
  constexpr bool invalid_precede_x(const unsigned char &input) {
    return input == 'a' || input == 'e';
  }

  // Used in valid_commas(): checks if the character after a comma is illegal.
  constexpr char i_subs[7] {'*','\0',',','^','\0','/',')'};
  constexpr bool is_invalid_subsidence(const unsigned char &input) {
    return input == i_subs[input % 7];
  }

  // Detects primary operators in expressions.
  constexpr char p_ops[6] {'*','+','\0','-','^','/'};
  constexpr bool is_primary_ops(const unsigned char &input) {
    return input == p_ops[input % 6];
  }

  // Checks if a character is a unary sign ('+' or '-').
  constexpr bool is_sign(const unsigned char &input) {
    return input == 43 || input == 45;  // '+' and '-'
  }

  // Used in implicit_mult(): characters that trigger implicit multiplication.
  // Example: "2x" or "(x)(y)" imply multiplication between operands.
  constexpr char imv_ch[25] {
    '2','3','4','5','6','7','8','9',
    '!','\0','#','\0','\0','\0','\0','(',
    ')','\0','\0','\0','x','\0','\0','0',
    '1'
  };
  constexpr bool implicit_mult_valid_char_find(const unsigned char &input) {
    return input == imv_ch[input % 25];
  }

  // Used in cleanup() or sanitization: valid tail characters.
  constexpr char bc_lch[17] {
    '3','4','5','6','7','8','9',')',
    '\0','\0','=','\0','.','@','0','1', // (=) is placeholder for pi and @ for euler's number.
    '2'
  };
  constexpr bool basic_cleanup_char_lookup(const unsigned char &input) {
    return input == bc_lch[input % 17];
  }

  // First-stage delimiter characters in binary_ops().
  constexpr char p_op_fd[8] {
    '(','\0','*','+',',','-','^','/'
  };
  constexpr bool primary_op_first_delimiter(const unsigned char &input) {
    return input == p_op_fd[input % 8];
  }

  // Second-stage delimiter characters in binary_ops().
  constexpr char p_op_sd[8] {
