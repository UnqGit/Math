  // Valid single-byte characters (ASCII only).
  constexpr char vc_sch[52] {
    '^','\0','\0','a','b','c','d','e','f','g','h','i','\0','k','l','m',
    'n','o','p','q','r','s','t','u','v','w','x','!','\0','\0','\0','\0',
