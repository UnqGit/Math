    // Return the outermost function name or the entire expression if there isn't a function.
    std::string om_function() const noexcept {
      // Get the string before the first opening parenthesis (if the expression is parsed properly).
      if(this -> anomaly) return empty_string;
      size_t t = this -> modified_expression.find(open_paren);
      if(t == std::string::npos) return empty_string;
      return this -> modified_expression.substr(0, t);
    }

    // Check if the outermost function is a binary function.
    bool is_om_binary() const noexcept {
      size_t t = modified_expression.find(open_paren);
      if(this -> anomaly || t == std::string::npos) return false;
      // return binary_funcs.find(this -> modified_expression.substr(0, t)) != binary_funcs.end();
      return is_binary_func(this -> modified_expression.substr(0, t));
    }

    // Check for unary functions.
    bool is_om_unary() const noexcept {
      if(this -> anomaly) return false;
      size_t t = modified_expression.find(open_paren);
      // return (t == std::string::npos) || binary_funcs.find(this -> modified_expression.substr(0, t)) == binary_funcs.end();
      return (t == std::string::npos) || !is_binary_func(this -> modified_expression.substr(0, t));
    }

    // Provide the first inner string inside the parenthesis (Does not separate the commas).
    std::string inner_string() const noexcept {
      size_t t  = this -> modified_expression.find(open_paren);
      if(this -> anomaly || t == std::string::npos) return empty_string;
      int len = this -> modified_expression.length();
      return this -> modified_expression.substr(t + 1, len - (t + 2));
    }

    // Returns the first inner expression as a string (whole expression if unary, or first operand in binary functions).
    std::string first_expression_str() const noexcept {
      // If the expression is invalid (anomaly detected), return an empty string.
      if(this -> anomaly) return empty_string;

      // Look for the first '('. If there's none, this isn't a function call — return the expression itself.
      size_t t = this -> modified_expression.find(open_paren);
      if(t == std::string::npos) return this -> modified_expression;

      // Grab the substring inside the parentheses.
      size_t len = this -> modified_expression.length();
      std::string inner_expr = this -> modified_expression.substr(t + 1, len - (t + 2));

      // If it's a unary function (like sqrt or neg), the whole inside is the first (and only) operand.
      if(this -> is_om_unary()) return inner_expr;

      // Otherwise, we need to find the first comma that separates the two operands.
      int parenthesis = 0, i = t + 1;
      const std::string& input = this -> modified_expression;
      for (; i < len - 1; i++) {
        if(input[i] == '(') parenthesis++;
        else if(input[i] == ')') parenthesis--;
        else if(input[i] == ',' && parenthesis == 0) break; // Found our comma at the top-level
      }

      // Return the substring from after '(' to just before the comma.
      return input.substr(t + 1, i - (t + 1));
    }
    
    // Returns the second inner expression as a string (only valid for binary functions).
    std::string second_expression_str() const noexcept {
      // If it's an invalid expression or unary function, there's no second operand to extract.
      if(this -> anomaly || this -> is_om_unary()) return empty_string;

      // Locate the opening parenthesis.
      size_t t = this -> modified_expression.find(open_paren);
      size_t len = this -> modified_expression.length();

      // Iterate to the comma that separates arguments.
      int parenthesis = 0, i = t + 1;
      const std::string& input = this -> modified_expression;
      for (; i < len - 1; i++) {
        if(input[i] == '(') parenthesis++;
        else if(input[i] == ')') parenthesis--;
        else if(input[i] == ',' && parenthesis == 0) break;
      }

      // Return the substring after the comma up to the closing parenthesis.
      return input.substr(i + 1, len - 2 - i);
    }
    
    // Returns the first inner expression as an `expression` object.
    // Acts like a smart parser inside a parser — inception style.
    expression first_expression() const noexcept {
      if(this -> anomaly) return expression(); // Bail early if invalid.

      size_t t = this -> modified_expression.find(open_paren);
      if(t == std::string::npos) return *this; // Not a function call? Return self.

      size_t len = this -> modified_expression.length();
      std::string inner_expr = this -> modified_expression.substr(t + 1, len - (t + 2));

      // For unary functions, return the sole inner expression as a new expression object.
      if(this -> is_om_unary()) {
        expression inner;
        inner.entered_expression = inner_expr;
        inner.modified_expression = inner_expr;
        inner.anomaly = false;
        inner.allow_variable = this -> allow_variable;
        inner.err_log = this -> err_log;
        return inner;
      }

      // For binary functions, find the first argument (before the comma).
      int parenthesis = 0, i = t + 1;
      const std::string& input = this -> modified_expression;
      for (; i < len - 1; i++) {
        if(input[i] == '(') parenthesis++;
        else if(input[i] == ')') parenthesis--;
        else if(input[i] == ',' && parenthesis == 0) break;
      }

      std::string new_expr = input.substr(t + 1, i - (t + 1));

      // Create and return an `expression` object containing the first argument.
      expression result;
      result.entered_expression = new_expr;
      result.modified_expression = new_expr;
      result.anomaly = false;
      result.allow_variable = this -> allow_variable;
      result.err_log = this -> err_log;
      return result;
    }
    
    // Returns the second inner expression as an `expression` object (only for binary functions).
    expression second_expression() const noexcept {
      if(this -> anomaly || this -> is_om_unary()) return expression(); // No second expression to find.

      size_t t = this -> modified_expression.find(open_paren);
      size_t len = this -> modified_expression.length();

      // Locate the comma that splits the operands.
      int parenthesis = 0, i = t + 1;
      const std::string& input = this -> modified_expression;
      for (; i < len - 1; i++) {
        if(input[i] == '(') parenthesis++;
        else if(input[i] == ')') parenthesis--;
        else if(input[i] == ',' && parenthesis == 0) break;
      }

      std::string new_expr = input.substr(i + 1, len - 2 - i);

      // Create a new `expression` object for the second operand.
      expression result;
      result.entered_expression = new_expr;
      result.modified_expression = new_expr;
      result.anomaly = false;
      result.allow_variable = this -> allow_variable;
      result.err_log = this -> err_log;
      return result;
    }

    // Swaping mechanism with another expression object.
    expression &swap(expression &other) noexcept {
      std::swap(this -> entered_expression, other.entered_expression);
      std::swap(this -> modified_expression, other.modified_expression);
      std::swap(this -> allow_variable, other.allow_variable);
      std::swap(this -> err_log, other.err_log);
      std::swap(this -> anomaly, other.anomaly);
      return *this;
    }

    // Compose another function into the current function by substituting 'x' with the other expression.
    // Essentially, perform function composition: f(g(x)) where 'this' is f and 'other' is g.
    expression compose(const expression &other) const noexcept {
      // If either expression is anomalous (broken), or if the other expression is just "x" (identity),
      // then no substitution needed—return the current expression as-is.
      if(this -> anomaly || other.anomaly || other.modified_expression == x_str) return *this;

      // Get the string form of the other expression to substitute in place of 'x'.
      const std::string &other_str = other.modified_expression;
      int len = other_str.length();

      // Start with a copy of the current expression to safely modify.
      expression result(*this);
      std::string &alias = result.modified_expression;

      // Find each occurrence of 'x' that is *not* preceded by an invalid character
      // (to avoid mistaking 'exp' or similar for the variable x).
      size_t t = alias.find(x_str);
      while (t != std::string::npos) {
        // Ensure 'x' is not part of something like 'exp' by checking the preceding char.
        if(t == 0 || (t > 0 && !invalid_precede_x(alias[t - 1]))) {
          // Replace this valid 'x' with the other expression string.
          alias.replace(t, 1, other_str);
          // Continue searching after the newly inserted string to avoid infinite loops.
          t = alias.find(x_str, t + len);
        } 
        else {
          // Skip this occurrence of 'x' because it's part of a larger token.
          t = alias.find(x_str, t + 1);
        }
      }

      // Return the composed expression.
      return result;
    }

    // Won't be handling any cases like any expression being 0, not the job of this file.
    // Operator overload for "adding" two expressions.
    expression operator+(const expression &other) const noexcept {
      if(this -> anomaly || other.anomaly) return *this;
      expression result(*this);
      std::string &current_str = result.modified_expression;
      const std::string &other_str = other.modified_expression;
      current_str = add_func_str + current_str + comma_str + other_str + close_paren;
