  // Used to replace the operators in order for BODMAS / PEMDAS presedence.
  const std::string op_str = "^/*-+";


  inline char to_lower(const char &c) noexcept {
    return (c > 64 && c < 91) ? c + 32 : c;
  }
  
  inline bool is_space(const char &c) {
    return c == 32 || c == 9 || c == 10;
  }

  inline bool is_lower(const char &c) noexcept {
    return c > 96 && c < 123;
  }

  inline bool is_digit(const char &c) noexcept {
    return c > 47 && c < 58;
  }

  inline bool is_low_num(const char &c) noexcept {
    return is_lower(c) || is_digit(c);
  }

  inline bool is_superscript(const char *ptr) noexcept {
    return ((*ptr == -30 && *(ptr + 1) == -127) || (*ptr == -62 && *(ptr + 1) != -73));
  }
  
  inline char superscript_to_ascci(const char *it, int size) noexcept {
    switch(size) {
      case 2:
        return *(it + 1) == -71 ? '1' : 48 + (80 + *(it + 1));
      case 3:
        return 48 + (80 + *(it + 2));
    }
    return 48;
  }

