    // Embed the current expression inside a given mathematical function.
    // If the function is binary (like pow or div), embed the other expression as the second argument.
    // If there's any anomaly or the function is not allowed (or is just "x"), return unchanged.
    expression embed_in(const std::string &function, const expression &other = expression()) const noexcept {
      if(this -> anomaly) return *this;

      // Can't embed into something that's not a recognized function or if it's just 'x' (the variable itself).
      if(!is_allowed_function(function) || function == x_str) return *this;

      // Copy this expression and mark it as a function now.
      expression result(*this);
      result.make_function();
      std::string &this_str = result.modified_expression;

      // If the function is binary, make sure the other expression is valid and include it as second argument.
      if(is_binary_func(function)) {
        if(other.anomaly) return *this;
        this_str = function + open_paren + this_str + comma_str + other.modified_expression + close_paren;
      } 
      else {
        // Unary function: just wrap the current expression inside the function call.
        this_str = function + open_paren + this_str + close_paren;
      }

      return result;
    }

    // Overload: same as above but accepts a C-style string literal for convenience.
    expression embed_in(const char* function, const expression &other = expression()) const noexcept {
      if(this -> anomaly) return *this;

      if(!is_allowed_function(function) || function == x_str) return *this;

      expression result(*this);
      result.make_function();
      std::string &this_str = result.modified_expression;

      if(is_binary_func(function)) {
        if(other.anomaly) return *this;
        this_str = function + open_paren + this_str + comma_str + other.modified_expression + close_paren;
      } 
      else {
        this_str = function + open_paren + this_str + close_paren;
      }

      return result;
    }

